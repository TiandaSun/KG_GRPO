#!/usr/bin/env bash
#SBATCH --job-name=p7_v14e1_eval
#SBATCH --nodes=1
#SBATCH --gpus=2
#SBATCH --cpus-per-task=144
#SBATCH --time=12:00:00
#SBATCH --output=logs/%x-%j.log
#SBATCH --error=logs/%x-%j.err
#SBATCH --partition=workq

# V14-E1 Qwen2.5-32B E5b-stabilized — post-GRPO eval.
#
# 1) Merge FSDP actor checkpoint at global_step_${STEP} → full HF model.
# 2) Start KG server.
# 3) Run full 3531-sample eval with trajectory save (for CvT classification).
#
# Memory: --gpus=2 (~230 GB CPU RAM). Single GPU (~115 GB) OOMed during FSDP
# merge — 32B has 64 GB weights, merger holds 16 shards + concat tensor in
# CPU mem, peak ~150-180 GB. Only the merge needs this; eval itself uses 1 GPU.
#
# Usage:
#   sbatch scripts/run_phase7_v14_d1_eval.job
#   STEP=400 sbatch --export=ALL,STEP=400 scripts/run_phase7_v14_d1_eval.job
#
# Default STEP=500. If GRPO stops early at 300/400, pass STEP=400 (or 300).

set -eo pipefail

source "$HOME/miniforge3/bin/activate"
conda activate kg_verl
module load cudatoolkit 2>/dev/null || true
module load gcc-native/14.2 2>/dev/null || true

export CC=gcc CXX=g++
export LIBRARY_PATH=/opt/nvidia/hpc_sdk/Linux_aarch64/24.11/REDIST/math_libs/12.6/targets/sbsa-linux/lib:${LIBRARY_PATH:-}
export HF_HOME=/scratch/u6gg/ts1201.u6gg/hf_cache
export PYTHONUNBUFFERED=1
export TMPDIR="/tmp"
export TRITON_CACHE_DIR=/scratch/u6gg/ts1201.u6gg/.triton

cd "$SLURM_SUBMIT_DIR"
export PYTHONPATH="$PWD:${PYTHONPATH:-}"

STEP="${STEP:-200}"
EXPERIMENT="${EXPERIMENT:-grpo-cwq-32b-e5b-4node-20260425}"
MODEL_TAG="v14_e1_qwen32b_e5b_step${STEP}"

BASE_MODEL="outputs/verl-sft-cwq-32b-from-base-merged"
SRC="/projects/u6gg/KG_GRPO/checkpoints/kg-align-verl/${EXPERIMENT}/global_step_${STEP}/actor"
DST="outputs/verl-sft-cwq-32b-${MODEL_TAG}-merged"
OUT_JSON="results/phase7/${MODEL_TAG}_full_test.json"
TRAJ_DIR="results/trajectories/phase7/${MODEL_TAG}_full"
PS_DIR="results/phase7/${MODEL_TAG}_full_per_sample"
KG_PORT=$((18000 + SLURM_JOB_ID % 1000))

mkdir -p results/phase7 "$TRAJ_DIR" "$PS_DIR" logs

echo "=== V14-E1 Eval: Qwen2.5-32B E5b @ step ${STEP} ==="
echo "Date: $(date)"
echo "Source (FSDP): $SRC"
echo "Dest (merged): $DST"
echo "Output JSON:   $OUT_JSON"
echo "Trajectories:  $TRAJ_DIR"

if [ ! -d "$SRC" ]; then
    echo "ERROR: FSDP checkpoint not found at $SRC"
    # Probe earlier steps for user guidance.
    for s in 400 300 200 100 50; do
        ALT="/projects/u6gg/KG_GRPO/checkpoints/kg-align-verl/${EXPERIMENT}/global_step_${s}/actor"
        if [ -d "$ALT" ]; then
            echo "Found step $s instead. Re-run with STEP=$s"
            break
        fi
    done
    exit 1
fi

# --- (1) Merge FSDP → HF ---
if [ ! -f "$DST/config.json" ]; then
    echo "=== Merging FSDP → HF ==="
    mkdir -p "$DST"
    python -m verl.model_merger merge \
        --backend fsdp \
        --local_dir "$SRC" \
        --target_dir "$DST"
    if [ ! -f "$DST/tokenizer.json" ]; then
        cp -n "$BASE_MODEL"/tokenizer* "$DST/" 2>/dev/null || true
        cp -n "$BASE_MODEL"/chat_template.jinja "$DST/" 2>/dev/null || true
    fi
    echo "Merge complete."
else
    echo "[skip] merged checkpoint already exists at $DST"
fi

# --- (2) KG server ---
python -m src_verl.kg_server.server --kg freebase --freebase_dir data/freebase/kg --port $KG_PORT --log-level warning &
KG_PID=$!
trap 'kill $KG_PID 2>/dev/null' EXIT
sleep 30
for i in $(seq 1 12); do
    curl -s -o /dev/null -w "%{http_code}" http://localhost:$KG_PORT/health 2>/dev/null | grep -q "200" && break
    sleep 10
done
echo "KG server ready on port $KG_PORT"

# --- (3) Eval ---
python scripts/eval_with_tools.py \
    --checkpoint_dir "$DST" \
    --steps 0 \
    --base_model "$DST" \
    --eval_data data/freebase/verl_cwq/test.parquet \
    --output "$OUT_JSON" \
    --kg_server_url http://localhost:$KG_PORT \
    --max_samples 0 \
    --max_turns 5 \
    --max_new_tokens 512 \
    --save_trajectories "$TRAJ_DIR" \
    --max_trajectory_samples 3531 \
    --save_per_sample "$PS_DIR"

kill $KG_PID 2>/dev/null

echo ""
echo "=== ${MODEL_TAG} summary ==="
python3 -c "
import json
d = json.load(open('$OUT_JSON'))
for step, r in d.items():
    print(f'  ${MODEL_TAG}: EM={r.get(\"em\", 0):.4f}  ContEM={r.get(\"contains_em\", 0):.4f}  F1={r.get(\"f1\", 0):.4f}  Tools={r.get(\"avg_tool_calls\", 0):.2f}')
"
echo "=== Done: $(date) ==="
