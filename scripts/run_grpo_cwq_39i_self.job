#!/usr/bin/env bash
#SBATCH --job-name=grpo_39i_s
#SBATCH --nodes=1
#SBATCH --gpus=4
#SBATCH --time=24:00:00
#SBATCH --output=logs/%x-%j.log
#SBATCH --error=logs/%x-%j.err
#SBATCH --partition=workq

# Task 39 Variant I-Self: deployable self-verifiable query reward.
#
# Init from 39B@400 (same as I-Oracle). Uses tool_type_bonus_retrieval_contrib
# reward: rewards tool calls where (a) observation is non-empty, AND (b) at
# least one returned entity appears verbatim in the final <answer>. Requires
# NO gold labels — fully self-verifiable at inference time.
#
# v11 key contribution: if I-Self gets close to I-Oracle's EM/CvT, we have
# "a self-verifiable process reward that nearly matches oracle supervision."
# If I-Self fails but I-Oracle succeeds, "oracle supervision is required" is
# the finding. Either way publishable.

set -eo pipefail

source "$HOME/miniforge3/bin/activate"
conda activate kg_verl
module load cudatoolkit 2>/dev/null || true
module load gcc-native/14.2 2>/dev/null || true
module load brics/nccl 2>/dev/null || true

export CC=gcc CXX=g++
export LIBRARY_PATH=/opt/nvidia/hpc_sdk/Linux_aarch64/24.11/REDIST/math_libs/12.6/targets/sbsa-linux/lib:${LIBRARY_PATH:-}
export TRITON_CACHE_DIR=/scratch/u6gg/ts1201.u6gg/.triton
export HF_HOME=/scratch/u6gg/ts1201.u6gg/hf_cache
export PYTHONUNBUFFERED=1
export VLLM_USE_V1=1
export RAY_DEDUP_LOGS=1
export RAY_TMPDIR="/tmp/ray-${SLURM_JOB_ID}"
mkdir -p "$RAY_TMPDIR"

cd "$SLURM_SUBMIT_DIR"
export PYTHONPATH="$PWD:${PYTHONPATH:-}"

export REWARD_TYPE=tool_type_bonus_retrieval_contrib
EXPERIMENT_NAME="grpo-cwq-7b-39i-self-20260415"
INIT_BASE="outputs/verl-sft-cwq-39b-step400"

echo "=== Task 39 Variant I-Self (4x GH200) ==="
echo "Date: $(date)"
echo "Reward: $REWARD_TYPE"
echo "Experiment: $EXPERIMENT_NAME"
echo "Init: $INIT_BASE  (39B @ step 400)"
echo "Train: full train.parquet (no oracle filter)"

if [ ! -d "$INIT_BASE" ]; then
    echo "ERROR: init base not found at $INIT_BASE"
    exit 1
fi

# KG server
python -m src_verl.kg_server.server --kg freebase --freebase_dir data/freebase/kg --port 18901 --log-level warning &
KG_PID=$!
trap 'kill $KG_PID 2>/dev/null' EXIT
sleep 30
for i in $(seq 1 12); do
    curl -s -o /dev/null -w "%{http_code}" http://localhost:18901/health 2>/dev/null | grep -q "200" && break
    sleep 10
done
echo "KG server ready"

ray stop 2>/dev/null || true

python -m verl.trainer.main_ppo \
    --config-path="$PWD/configs_verl" \
    --config-name=grpo_cwq_7b \
    trainer.experiment_name="$EXPERIMENT_NAME" \
    trainer.total_training_steps=400 \
    actor_rollout_ref.model.path="$INIT_BASE" \
    actor_rollout_ref.actor.use_kl_loss=true \
    actor_rollout_ref.actor.kl_loss_coef=0.05 \
    actor_rollout_ref.actor.kl_loss_type=low_var_kl \
    actor_rollout_ref.actor.optim.lr=3e-7 \
    +actor_rollout_ref.rollout.enable_sleep_mode=true \
    actor_rollout_ref.rollout.agent.default_agent_loop=tool_agent \
    data.dataloader_num_workers=0

kill $KG_PID 2>/dev/null
echo "=== Done: $(date) ==="
