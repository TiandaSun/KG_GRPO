#!/usr/bin/env bash
#SBATCH --job-name=p7_s11_g3sft
#SBATCH --nodes=1
#SBATCH --gpus=4
#SBATCH --time=12:00:00
#SBATCH --output=logs/%x-%j.log
#SBATCH --error=logs/%x-%j.err
#SBATCH --partition=workq

# S1.1 — G3 ablation SFT (single seed=42).
#
# Difference vs G2:
#   - G2 init = outputs/verl-sft-cwq-7b-merged   (rule-based pre-SFT)
#   - G3 init = Qwen/Qwen2.5-7B-Instruct          (RAW HF base — skip pre-SFT)
# Everything else is identical to run_phase7_s02_g2_sft_seed.job:
#   - Train file: data/freebase/verl_cwq/39b_self_distill.jsonl  (14,082 trajectories)
#   - 1 epoch, LoRA + merge
#   - Default seed=42 (single seed; SFTConfig data_seed = seed)
#
# Confirmed base HF id from configs_verl/sft_cwq.yaml: model_name: "Qwen/Qwen2.5-7B-Instruct"
#
# Usage:
#   sbatch scripts/run_phase7_s11_g3_sft.job

set -eo pipefail

source "$HOME/miniforge3/bin/activate"
conda activate kg_verl
module load cudatoolkit 2>/dev/null || true
module load gcc-native/14.2 2>/dev/null || true

export CC=gcc CXX=g++
export LIBRARY_PATH=/opt/nvidia/hpc_sdk/Linux_aarch64/24.11/REDIST/math_libs/12.6/targets/sbsa-linux/lib:${LIBRARY_PATH:-}
export TRITON_CACHE_DIR=/scratch/u6gg/ts1201.u6gg/.triton
export HF_HOME=/scratch/u6gg/ts1201.u6gg/hf_cache
export PYTHONUNBUFFERED=1
export TMPDIR="/tmp"

cd "$SLURM_SUBMIT_DIR"
export PYTHONPATH="$PWD:${PYTHONPATH:-}"

SEED=42
INIT_BASE="Qwen/Qwen2.5-7B-Instruct"
TRAIN_FILE="data/freebase/verl_cwq/39b_self_distill.jsonl"
OUTPUT_DIR="outputs/verl-sft-cwq-7b-G3-from-rawbase"
MERGED_DIR="outputs/verl-sft-cwq-7b-G3-from-rawbase-merged"
WANDB_RUN="sft-cwq-7b-G3-from-rawbase-20260427"

echo "=== S1.1 G3 SFT seed=${SEED} (4x GH200) ==="
echo "Date: $(date)"
echo "Init: $INIT_BASE  (RAW HF base — no rule-based pre-SFT)"
echo "Train: $TRAIN_FILE"
echo "Output: $OUTPUT_DIR"
echo "Merged: $MERGED_DIR"

[ -f "$TRAIN_FILE" ] || { echo "ERROR: $TRAIN_FILE not found"; exit 1; }
TRAIN_LINES=$(wc -l < "$TRAIN_FILE")
echo "Trajectories in $TRAIN_FILE: $TRAIN_LINES (expected 14082)"

python src_verl/training/sft_multiturn.py \
    --config configs_verl/sft_cwq.yaml \
    --model_path "$INIT_BASE" \
    --output_dir "$OUTPUT_DIR" \
    --num_train_epochs 1 \
    --train_file "$TRAIN_FILE" \
    --seed "$SEED" \
    --wandb_run_name "$WANDB_RUN"

echo ""
echo "=== Merge LoRA adapter ==="
python scripts/merge_sft_adapter.py \
    --base_model "$INIT_BASE" \
    --adapter_path "$OUTPUT_DIR" \
    --output_path "$MERGED_DIR"

# For raw HF base model the tokenizer comes from the HF cache via the merger; no
# local tokenizer files to copy. (G2 copied from a local merged dir.)
# Defensive: ensure the merged dir has a tokenizer (the merger normally writes it).
if [ ! -f "$MERGED_DIR/tokenizer.json" ]; then
    echo "WARN: tokenizer.json missing in $MERGED_DIR; verify before GRPO."
fi

echo ""
echo "=== Done: $(date) ==="
echo "Merged checkpoint: $MERGED_DIR"
