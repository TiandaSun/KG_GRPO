#!/usr/bin/env bash
#SBATCH --job-name=p7_v15_q8_grpo
#SBATCH --nodes=1
#SBATCH --gpus=4
#SBATCH --time=24:00:00
#SBATCH --output=logs/%x-%j.log
#SBATCH --error=logs/%x-%j.err
#SBATCH --partition=workq

# V15-Q8 Lane 8 step 3: GRPO on synthetic-schema CWQ.
#
# Mirrors scripts/run_grpo_cwq_39i_self.job (the I-Self / 39I recipe):
#   - Reward: tool_type_bonus_retrieval_contrib
#   - lr: 3e-7
#   - 400 GRPO steps total
#   - Save every 50 steps
# Differences:
#   - KL=0.25 (the I-Self setting per Lane 8 spec, NOT 0.05)
#   - Init from outputs/verl-sft-cwq-7b-q8-synthetic-merged
#   - Train data: data/freebase/verl_cwq_q8_synthetic/{train,val}.parquet
#   - KG server runs in q8_synthetic mode (URI <-> original translation)

set -eo pipefail

source "$HOME/miniforge3/bin/activate"
conda activate kg_verl
module load cudatoolkit 2>/dev/null || true
module load gcc-native/14.2 2>/dev/null || true
module load brics/nccl 2>/dev/null || true

export CC=gcc CXX=g++
export LIBRARY_PATH=/opt/nvidia/hpc_sdk/Linux_aarch64/24.11/REDIST/math_libs/12.6/targets/sbsa-linux/lib:${LIBRARY_PATH:-}
export TRITON_CACHE_DIR=/scratch/u6gg/ts1201.u6gg/.triton
export HF_HOME=/scratch/u6gg/ts1201.u6gg/hf_cache
export PYTHONUNBUFFERED=1
export VLLM_USE_V1=1
export RAY_DEDUP_LOGS=1
export RAY_TMPDIR="/tmp/ray-${SLURM_JOB_ID}"
mkdir -p "$RAY_TMPDIR"

cd "$SLURM_SUBMIT_DIR"
export PYTHONPATH="$PWD:${PYTHONPATH:-}"

export REWARD_TYPE=tool_type_bonus_retrieval_contrib
EXPERIMENT_NAME="grpo-cwq-7b-q8-synthetic-20260506"
INIT_BASE="outputs/verl-sft-cwq-7b-q8-synthetic-merged"
TRAIN_PARQUET="data/freebase/verl_cwq_q8_synthetic/train.parquet"
VAL_PARQUET="data/freebase/verl_cwq_q8_synthetic/val.parquet"
Q8_MAPPING="data/freebase/verl_cwq_q8_synthetic/entity_mapping.json"
KG_PORT=18908

echo "=== V15-Q8 GRPO (4x GH200, single-node) ==="
echo "Date: $(date)"
echo "Reward: $REWARD_TYPE"
echo "Experiment: $EXPERIMENT_NAME"
echo "Init: $INIT_BASE"
echo "Train: $TRAIN_PARQUET"
echo "Val: $VAL_PARQUET"
echo "KL: 0.25 (I-Self setting per Lane 8 spec)"
echo "Steps: 400, save every 50"

[ -d "$INIT_BASE" ] || { echo "ERROR: init base $INIT_BASE not found"; exit 1; }
[ -f "$TRAIN_PARQUET" ] || { echo "ERROR: $TRAIN_PARQUET not found"; exit 1; }
[ -f "$VAL_PARQUET" ] || { echo "ERROR: $VAL_PARQUET not found"; exit 1; }
[ -f "$Q8_MAPPING" ] || { echo "ERROR: $Q8_MAPPING not found"; exit 1; }

# --- KG server in q8_synthetic mode ---
python -m src_verl.kg_server.server \
    --kg q8_synthetic \
    --freebase_dir data/freebase/kg \
    --q8_mapping_path "$Q8_MAPPING" \
    --port $KG_PORT \
    --log-level warning &
KG_PID=$!
trap 'kill $KG_PID 2>/dev/null' EXIT
sleep 30
for i in $(seq 1 12); do
    curl -s -o /dev/null -w "%{http_code}" http://localhost:$KG_PORT/health 2>/dev/null | grep -q "200" && break
    sleep 10
done
echo "KG server (q8_synthetic) ready on port $KG_PORT"

ray stop 2>/dev/null || true

python -m verl.trainer.main_ppo \
    --config-path="$PWD/configs_verl" \
    --config-name=grpo_cwq_7b \
    trainer.experiment_name="$EXPERIMENT_NAME" \
    trainer.total_training_steps=400 \
    trainer.save_freq=50 \
    trainer.test_freq=50 \
    data.train_files=["$TRAIN_PARQUET"] \
    data.val_files=["$VAL_PARQUET"] \
    actor_rollout_ref.model.path="$INIT_BASE" \
    ++actor_rollout_ref.actor.use_kl_loss=true \
    ++actor_rollout_ref.actor.kl_loss_coef=0.25 \
    ++actor_rollout_ref.actor.kl_loss_type=low_var_kl \
    ++actor_rollout_ref.actor.optim.lr=3e-7 \
    +actor_rollout_ref.rollout.enable_sleep_mode=true \
    actor_rollout_ref.rollout.agent.default_agent_loop=tool_agent \
    data.dataloader_num_workers=0

kill $KG_PID 2>/dev/null
echo "=== Done: $(date) ==="
