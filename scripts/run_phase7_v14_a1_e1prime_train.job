#!/usr/bin/env bash
#SBATCH --job-name=p7_e1prime
#SBATCH --nodes=1
#SBATCH --gpus=4
#SBATCH --time=24:00:00
#SBATCH --output=logs/%x-%j.log
#SBATCH --error=logs/%x-%j.err
#SBATCH --partition=workq

# V14-A1 Option 4: E1' — our verl + binary-EM outcome reward + Search-R1's
# published hyperparameters. Single config change, zero env risk.
#
# Search-R1 (arXiv:2503.09516) config (from their repo + paper):
#   reward      = binary EM on final <answer>
#   kl_coef     = 0.001   (vs our default 0.05 for E5b-stabilized)
#   lr          = 1e-6
#   batch       = 256
#   max_steps   = 800
#   tools       = single search() endpoint (we use our 4-tool native interface —
#                 this is the one deviation, since adapting to single-tool
#                 requires Search-R1's training loop code which we can't run)
#
# Init from the same SFT base as E1/E3/E5b (not 39B@400), matching Search-R1's
# "train from base model" protocol.
#
# Expected outcome (hypothesis for paper):
#   - If EM > 30% → Search-R1's recipe transfers partially to CWQ; paper reframe
#   - If EM < 10% → confirms Section-6 constructive claim (E5b > outcome-only)
#   - Middle (10-30%) → subtle story, still paper-worthy.

set -eo pipefail

source "$HOME/miniforge3/bin/activate"
conda activate kg_verl
module load cudatoolkit 2>/dev/null || true
module load gcc-native/14.2 2>/dev/null || true
module load brics/nccl 2>/dev/null || true

export CC=gcc CXX=g++
export LIBRARY_PATH=/opt/nvidia/hpc_sdk/Linux_aarch64/24.11/REDIST/math_libs/12.6/targets/sbsa-linux/lib:${LIBRARY_PATH:-}
export TRITON_CACHE_DIR=/scratch/u6gg/ts1201.u6gg/.triton
export HF_HOME=/scratch/u6gg/ts1201.u6gg/hf_cache
export PYTHONUNBUFFERED=1
export VLLM_USE_V1=1
export RAY_DEDUP_LOGS=1
export RAY_TMPDIR="/tmp/ray-${SLURM_JOB_ID}"
export TMPDIR="/tmp"
mkdir -p "$RAY_TMPDIR"

cd "$SLURM_SUBMIT_DIR"
export PYTHONPATH="$PWD:${PYTHONPATH:-}"

export REWARD_TYPE=outcome_em_only
EXPERIMENT_NAME="grpo-cwq-7b-e1prime-20260420"
INIT_BASE="outputs/verl-sft-cwq-7b-merged"

echo "=== V14-A1 E1' (Search-R1-equivalent) training on 4x GH200 ==="
echo "Date: $(date)"
echo "Reward: $REWARD_TYPE  (pure binary EM)"
echo "KL: 0.001 (Search-R1)  LR: 1e-6  Batch: 256  max_steps: 800"
echo "Init: $INIT_BASE"
echo "Experiment: $EXPERIMENT_NAME"

if [ ! -d "$INIT_BASE" ]; then
    echo "ERROR: init base not found at $INIT_BASE"
    exit 1
fi

# KG server
python -m src_verl.kg_server.server --kg freebase --freebase_dir data/freebase/kg --port 18901 --log-level warning &
KG_PID=$!
trap 'kill $KG_PID 2>/dev/null' EXIT
sleep 30
for i in $(seq 1 12); do
    curl -s -o /dev/null -w "%{http_code}" http://localhost:18901/health 2>/dev/null | grep -q "200" && break
    sleep 10
done
echo "KG server ready"

ray stop 2>/dev/null || true

# NOTE: total_training_steps is kept at 500 (not 800) for the 24h walltime window.
# Search-R1 paper curves converge around step 400-500; this gives the fairest
# comparison within one walltime. Continuation is trivial via afterok if needed.
python -m verl.trainer.main_ppo \
    --config-path="$PWD/configs_verl" \
    --config-name=grpo_cwq_7b \
    trainer.experiment_name="$EXPERIMENT_NAME" \
    trainer.total_training_steps=500 \
    trainer.save_freq=50 \
    trainer.test_freq=50 \
    actor_rollout_ref.model.path="$INIT_BASE" \
    actor_rollout_ref.actor.use_kl_loss=true \
    actor_rollout_ref.actor.kl_loss_coef=0.001 \
    actor_rollout_ref.actor.kl_loss_type=low_var_kl \
    actor_rollout_ref.actor.optim.lr=1e-6 \
    data.train_batch_size=256 \
    +actor_rollout_ref.rollout.enable_sleep_mode=true \
    actor_rollout_ref.rollout.agent.default_agent_loop=tool_agent \
    data.dataloader_num_workers=0

kill $KG_PID 2>/dev/null
echo "=== Done: $(date) ==="
