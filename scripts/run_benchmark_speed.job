#!/usr/bin/env bash
#SBATCH --job-name=bench_speed
#SBATCH --nodes=1
#SBATCH --gpus=4
#SBATCH --time=04:00:00
#SBATCH --output=logs/%x-%j.log
#SBATCH --error=logs/%x-%j.err
#SBATCH --partition=workq

# =============================================================================
# GRPO Training Speed Benchmark
# Runs 6 configurations sequentially on the same node to measure speedup
# from proposed optimizations. Each config runs 15 steps (3 warmup + 12 measured).
# =============================================================================

# NOTE: no set -e — individual config failures must not abort remaining configs

# --- Environment setup (standard Isambard GH200) ---
source "$HOME/miniforge3/bin/activate"
conda activate kg_verl
module load cudatoolkit 2>/dev/null || true
module load gcc-native/14.2 2>/dev/null || true
module load brics/nccl 2>/dev/null || true

export CC=gcc CXX=g++
export LIBRARY_PATH=/opt/nvidia/hpc_sdk/Linux_aarch64/24.11/REDIST/math_libs/12.6/targets/sbsa-linux/lib:${LIBRARY_PATH:-}
export TRITON_CACHE_DIR=/scratch/u6gg/ts1201.u6gg/.triton
export HF_HOME=/scratch/u6gg/ts1201.u6gg/hf_cache
export PYTHONUNBUFFERED=1
export VLLM_USE_V1=1
export RAY_DEDUP_LOGS=1
export RAY_TMPDIR="/tmp/ray-${SLURM_JOB_ID}"
mkdir -p "$RAY_TMPDIR"

cd "$SLURM_SUBMIT_DIR"
export PYTHONPATH="$PWD:${PYTHONPATH:-}"
export REWARD_TYPE=verifiable  # Use E3 reward (most representative — 1 tool call/step)

# --- Benchmark parameters ---
WARMUP_STEPS=3
MEASURE_STEPS=12
TOTAL_STEPS=$((WARMUP_STEPS + MEASURE_STEPS))
RESULTS_DIR="results/benchmark_${SLURM_JOB_ID}"
mkdir -p "$RESULTS_DIR"

echo "============================================="
echo "GRPO Speed Benchmark"
echo "Date: $(date)"
echo "Node: $(hostname)"
echo "Job ID: ${SLURM_JOB_ID}"
echo "Steps per config: ${TOTAL_STEPS} (${WARMUP_STEPS} warmup + ${MEASURE_STEPS} measured)"
echo "Results: ${RESULTS_DIR}/"
echo "============================================="
echo ""

# --- KG server management ---
KG_PID=""

start_kg_server() {
    local workers=${1:-1}
    echo "Starting KG server (workers=${workers})..."
    python -m src_verl.kg_server.server \
        --kg freebase --freebase_dir data/freebase/kg \
        --port 18901 --log-level warning --workers "$workers" > "${RESULTS_DIR}/kg_server_${workers}w.log" 2>&1 &
    KG_PID=$!
    # Freebase has 2.6M entities — loading takes 30-60s per worker
    local wait_time=$((30 + workers * 30))
    sleep "$wait_time"
    for i in $(seq 1 12); do
        if curl -s -o /dev/null -w "%{http_code}" http://localhost:18901/health 2>/dev/null | grep -q "200"; then
            echo "KG server healthy (PID=${KG_PID})"
            return 0
        fi
        sleep 10
    done
    echo "FATAL: KG server failed to start"
    return 1
}

stop_kg_server() {
    if [ -n "$KG_PID" ]; then
        kill "$KG_PID" 2>/dev/null
        wait "$KG_PID" 2>/dev/null || true
        KG_PID=""
        echo "KG server stopped"
    fi
    # Kill any remaining server processes on port 18901
    fuser -k 18901/tcp 2>/dev/null || true
    sleep 2
}

# --- Benchmark runner ---
run_benchmark() {
    local config_name="$1"
    local kg_workers="$2"
    shift 2
    local hydra_overrides=("$@")

    echo ""
    echo "===== CONFIG: ${config_name} ====="
    echo "Start: $(date)"
    echo "KG workers: ${kg_workers}"
    echo "Hydra overrides: ${hydra_overrides[*]:-none}"

    # Restart KG server with specified workers
    stop_kg_server
    if ! start_kg_server "$kg_workers"; then
        echo "SKIP ${config_name}: KG server failed"
        echo "${config_name},-1,0" >> "${RESULTS_DIR}/wall_times.csv"
        echo "===== DONE: ${config_name} (SKIPPED) ====="
        return 0  # non-fatal
    fi

    # Clean Ray between runs
    ray stop 2>/dev/null || true
    sleep 5

    # Set file logger path for this config
    export VERL_FILE_LOGGER_PATH="${RESULTS_DIR}/${config_name}.jsonl"

    local start_time
    start_time=$(date +%s)

    timeout 1800 python -m verl.trainer.main_ppo \
        --config-path="$PWD/configs_verl" \
        --config-name=grpo_cwq_7b \
        trainer.experiment_name="bench-${config_name}-${SLURM_JOB_ID}" \
        trainer.total_training_steps=$TOTAL_STEPS \
        trainer.save_freq=99999 \
        trainer.test_freq=99999 \
        trainer.val_before_train=false \
        +actor_rollout_ref.rollout.enable_sleep_mode=true \
        actor_rollout_ref.rollout.agent.default_agent_loop=tool_agent \
        data.dataloader_num_workers=0 \
        'trainer.logger=[console,wandb,file]' \
        trainer.project_name="kg-align-bench" \
        "${hydra_overrides[@]}" \
        > "${RESULTS_DIR}/${config_name}_stdout.log" 2>"${RESULTS_DIR}/${config_name}_stderr.log" \
        || true  # non-fatal
    local exit_code=${PIPESTATUS[0]:-$?}

    local end_time
    end_time=$(date +%s)
    local wall_time=$((end_time - start_time))

    echo "Exit code: ${exit_code}"
    echo "Wall time: ${wall_time}s ($((wall_time / 60))m $((wall_time % 60))s)"

    # Check for OOM in stderr
    if grep -q "CUDA out of memory\|OutOfMemoryError" "${RESULTS_DIR}/${config_name}_stderr.log" 2>/dev/null; then
        echo "WARNING: OOM detected in ${config_name}"
    fi

    # Record wall time
    echo "${config_name},${exit_code},${wall_time}" >> "${RESULTS_DIR}/wall_times.csv"

    echo "End: $(date)"
    echo "===== DONE: ${config_name} ====="
}

# --- Initialize wall times CSV ---
echo "config,exit_code,wall_time_s" > "${RESULTS_DIR}/wall_times.csv"

# =============================================================================
# Run 6 benchmark configurations
# =============================================================================

# Config 1: BASELINE (current config as-is)
run_benchmark "baseline" 1

# Config 2: Increased vLLM GPU memory utilization (0.4 → 0.6)
run_benchmark "opt_gpu_mem" 1 \
    actor_rollout_ref.rollout.gpu_memory_utilization=0.6

# Config 3: Increased actor micro-batch size (2 → 4)
run_benchmark "opt_micro_batch" 1 \
    actor_rollout_ref.actor.ppo_micro_batch_size_per_gpu=4

# Config 4: Increased ref log-prob micro-batch size (4 → 8)
run_benchmark "opt_ref_batch" 1 \
    actor_rollout_ref.ref.log_prob_micro_batch_size_per_gpu=8

# Config 5: KG server with 4 workers (instead of 1)
run_benchmark "opt_kg_workers" 4

# Config 6: All optimizations combined
run_benchmark "all_combined" 4 \
    actor_rollout_ref.rollout.gpu_memory_utilization=0.6 \
    actor_rollout_ref.actor.ppo_micro_batch_size_per_gpu=4 \
    actor_rollout_ref.ref.log_prob_micro_batch_size_per_gpu=8

# =============================================================================
# Post-processing
# =============================================================================

stop_kg_server
ray stop 2>/dev/null || true

echo ""
echo "============================================="
echo "All configs complete. Running analysis..."
echo "============================================="

python scripts/analyze_benchmark.py "$RESULTS_DIR" --warmup=$WARMUP_STEPS

echo ""
echo "Results saved to: ${RESULTS_DIR}/benchmark_summary.txt"
echo "Benchmark complete: $(date)"
