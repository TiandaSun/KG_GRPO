#!/usr/bin/env bash
#SBATCH --job-name=kg_eval_7b
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=8
#SBATCH --mem=64G
#SBATCH --time=72:00:00
#SBATCH --account=cs-ontrel-2021
#SBATCH --mail-type=END,FAIL
#SBATCH --mail-user=tianda.sun@york.ac.uk
#SBATCH --output=logs_archive/%x-%j.log
#SBATCH --error=logs_archive/%x-%j.err
#SBATCH --partition=gpuplus
#SBATCH --gpus-per-node=2

# Stage 6 (7B): 3-way Evaluation (Base vs SFT vs SFT+GRPO)
# Evaluates on ConceptNet (in-domain) and HotpotQA (transfer).
# Also evaluates on MMLU/ARC-Challenge (general capability check).
# Estimated runtime: ~12-20 hours on 1x H100.

set -eo pipefail

# --- Environment Setup ---
module load Miniconda3
module load CUDA/12.1.1
source activate kg_align

export HF_HOME=/mnt/scratch/users/ts1201/hf_cache
export TORCH_HOME=/mnt/scratch/users/ts1201/torch_cache
export WANDB_PROJECT=kg-align-rl

cd /mnt/scratch/users/ts1201/KG_lora
export PYTHONPATH=/mnt/scratch/users/ts1201/KG_lora:${PYTHONPATH:-}

echo "=== Stage 6 (7B): Evaluation ==="
echo "Date: $(date)"
echo "Node: $(hostname)"
echo "GPU: $(nvidia-smi --query-gpu=name --format=csv,noheader)"
echo ""

python src/evaluation/evaluate.py \
    --benchmark both \
    --base_model Qwen/Qwen2.5-7B-Instruct \
    --sft_adapter outputs/sft-warmup-7b \
    --grpo_adapter outputs/grpo-7b/phase3_all \
    --output_dir outputs/eval-7b \
    --num_samples 500 \
    --num_qualitative 20

echo ""
echo "=== Stage 6 (7B) Complete ==="
echo "End: $(date)"
echo ""
echo "Output files:"
ls -lh outputs/eval-7b/
