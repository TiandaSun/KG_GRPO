#!/usr/bin/env bash
#SBATCH --job-name=p7_v17_w17_2_baseline
#SBATCH --nodes=1
#SBATCH --gpus=4
#SBATCH --cpus-per-task=72
#SBATCH --time=12:00:00
#SBATCH --output=logs/%x-%j.log
#SBATCH --error=logs/%x-%j.err
#SBATCH --partition=workq

# v17 W17.2 — Full 3531-Q CWQ test eval on the W17.1f-Base merged checkpoint.
# Establishes the SFT-only baseline before GRPO. Chunked across 4 GPUs (882/882/882/885)
# WITH FOUR INDEPENDENT KG-SERVERS to eliminate tool-call contention (single-server
# variant ran 3.3x slower than expected — first attempt 4550981 cancelled).
# Walltime extended to 12h.

set -eo pipefail

source "$HOME/miniforge3/bin/activate"
conda activate kg_verl
module load cudatoolkit 2>/dev/null || true
module load gcc-native/14.2 2>/dev/null || true

export CC=gcc CXX=g++
export LIBRARY_PATH=/opt/nvidia/hpc_sdk/Linux_aarch64/24.11/REDIST/math_libs/12.6/targets/sbsa-linux/lib:${LIBRARY_PATH:-}
export TRITON_CACHE_DIR=/scratch/u6gg/ts1201.u6gg/.triton
export HF_HOME=/scratch/u6gg/ts1201.u6gg/hf_cache
export HF_TOKEN=$(cat "$HOME/.cache/huggingface/token" 2>/dev/null)
export PYTHONUNBUFFERED=1
export TMPDIR="/tmp"

cd "$SLURM_SUBMIT_DIR"
export PYTHONPATH="$PWD:${PYTHONPATH:-}"

MERGED_DIR="outputs/v17_llama_w17_1f_base_gate_sft-merged"
EVAL_DATA="data/freebase/verl_cwq/test.parquet"
OUT_DIR="_handoff/data/v17_llama"
KG_PORT_BASE=$((19800 + SLURM_JOB_ID % 80))  # 4 ports: base, base+1, base+2, base+3

[ -d "$MERGED_DIR" ] || { echo "ERROR: $MERGED_DIR not found"; exit 1; }
[ -f "$EVAL_DATA" ]  || { echo "ERROR: $EVAL_DATA not found"; exit 1; }

mkdir -p "$OUT_DIR" logs

echo "=== v17 W17.2 SFT-only baseline (chunked-4 + 4 KG servers, 3531 Q) ==="
echo "Date: $(date)"
echo "Model: $MERGED_DIR"

# --- Spawn 4 KG servers (one per chunk; ~3-4GB RAM each) ---
KG_PIDS=()
for k in 0 1 2 3; do
    port=$((KG_PORT_BASE + k))
    python -m src_verl.kg_server.server --kg freebase --freebase_dir data/freebase/kg \
        --port $port --log-level warning &
    KG_PIDS+=($!)
done
trap 'for pid in "${KG_PIDS[@]}"; do kill $pid 2>/dev/null; done; wait 2>/dev/null' EXIT
echo "Started 4 KG servers at ports $KG_PORT_BASE-$((KG_PORT_BASE+3))"
sleep 45
for k in 0 1 2 3; do
    port=$((KG_PORT_BASE + k))
    for i in $(seq 1 12); do
        curl -s -o /dev/null -w "%{http_code}" http://localhost:$port/health 2>/dev/null | grep -q "200" && break
        sleep 10
    done
    echo "KG server $k ready at port $port"
done

run_chunk() {
    local idx="$1"
    local start="$2"
    local n="$3"
    local kg_port=$((KG_PORT_BASE + idx))
    local out_json="${OUT_DIR}/w17_2_baseline_chunk${idx}.json"
    local ps_dir="${OUT_DIR}/w17_2_baseline_chunk${idx}_per_sample"
    local traj_dir="${OUT_DIR}/w17_2_baseline_chunk${idx}_trajectories"
    local logfile="logs/p7_v17_w17_2_baseline-${SLURM_JOB_ID}-gpu${idx}.log"

    mkdir -p "$ps_dir" "$traj_dir"

    {
        echo "=== GPU $idx KG-port=$kg_port start=$start n=$n  $(date) ==="
        CUDA_VISIBLE_DEVICES=$idx python scripts/eval_with_tools.py \
            --checkpoint_dir "$MERGED_DIR" \
            --steps 0 \
            --base_model "$MERGED_DIR" \
            --eval_data "$EVAL_DATA" \
            --output "$out_json" \
            --kg_server_url "http://localhost:$kg_port" \
            --start_idx $start \
            --max_samples $n \
            --max_turns 5 \
            --max_new_tokens 512 \
            --save_every 100 \
            --save_per_sample "$ps_dir" \
            --save_trajectories "$traj_dir" \
            --max_trajectory_samples $n \
            --resume
        echo "=== GPU $idx done $(date) ==="
    } > "$logfile" 2>&1
}

run_chunk 0 0    882 &
PID0=$!
run_chunk 1 882  882 &
PID1=$!
run_chunk 2 1764 882 &
PID2=$!
run_chunk 3 2646 885 &
PID3=$!

fail=0
wait $PID0 || fail=1
wait $PID1 || fail=1
wait $PID2 || fail=1
wait $PID3 || fail=1

# --- Aggregate ---
echo "=== Aggregating chunks $(date) ==="
python3 << PYEOF
import json
from pathlib import Path

merged_per_sample = []
merged_traj = []
em=cm=f1=tools=0.0
n=0

for idx in range(4):
    pf = Path("$OUT_DIR") / f"w17_2_baseline_chunk{idx}_per_sample/step_0_per_sample.json"
    if pf.exists():
        with open(pf) as f:
            data = json.load(f)
        merged_per_sample.extend(data)
        for r in data:
            em += r.get("em",0); cm += r.get("contains_em",0)
            f1 += r.get("f1",0); tools += r.get("num_tool_calls",0); n += 1
    tf = Path("$OUT_DIR") / f"w17_2_baseline_chunk{idx}_trajectories/step_0/trajectories.json"
    if tf.exists():
        with open(tf) as f:
            merged_traj.extend(json.load(f))

if n == 0:
    print("ERROR: no per-sample data merged"); exit(1)

result = {"0": {"em": em/n, "contains_em": cm/n, "f1": f1/n,
                "avg_tool_calls": tools/n, "n_samples": n}}
out_dir = Path("$OUT_DIR")
with open(out_dir / "w17_2_baseline_full_test.json", "w") as f:
    json.dump(result, f, indent=2)
print(f"Wrote w17_2_baseline_full_test.json: EM={em/n:.4f} ContEM={cm/n:.4f} F1={f1/n:.4f} Tools={tools/n:.2f} (n={n})")

ps_dir = out_dir / "w17_2_baseline_full_per_sample"
ps_dir.mkdir(parents=True, exist_ok=True)
with open(ps_dir / "step_0_per_sample.json", "w") as f:
    json.dump(merged_per_sample, f, indent=2)
traj_dir = out_dir / "w17_2_baseline_full_trajectories/step_0"
traj_dir.mkdir(parents=True, exist_ok=True)
with open(traj_dir / "trajectories.json", "w") as f:
    json.dump(merged_traj, f, indent=2, ensure_ascii=False)
print(f"Wrote merged trajectories ({len(merged_traj)})")
PYEOF

for pid in "${KG_PIDS[@]}"; do kill $pid 2>/dev/null; done
echo "=== Done $(date) ==="
exit $fail
