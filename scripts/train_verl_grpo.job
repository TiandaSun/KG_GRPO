#!/usr/bin/env bash
#SBATCH --job-name=verl_grpo
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=16
#SBATCH --mem=192G
#SBATCH --time=24:00:00
#SBATCH --account=cs-ontrel-2021
#SBATCH --mail-type=END,FAIL
#SBATCH --mail-user=tianda.sun@york.ac.uk
#SBATCH --output=logs/%x-%j.log
#SBATCH --error=logs/%x-%j.err
#SBATCH --partition=gpuplus
#SBATCH --gpus-per-node=1

# GRPO training with verl (1x H100 for 1.5B)
# Starts KG server as background process on the same node, then trains.
#
# Set REWARD_TYPE before submitting:
#   REWARD_TYPE=outcome     sbatch scripts/train_verl_grpo.job   # E1
#   REWARD_TYPE=heuristic   sbatch scripts/train_verl_grpo.job   # E2
#   REWARD_TYPE=verifiable  sbatch scripts/train_verl_grpo.job   # E3 (default)
#
# Prerequisites:
#   - SFT warmup complete (outputs/verl-sft/)
#   - Data prepared (data/processed/verl_conceptnet/train.parquet)

set -eo pipefail

# --- Environment Setup ---
module load Miniconda3
module load CUDA/12.8.0
source activate kg_verl

cd /mnt/scratch/users/ts1201/KG_lora
export PYTHONPATH=/mnt/scratch/users/ts1201/KG_lora:${PYTHONPATH:-}
export HF_HOME=/mnt/scratch/users/ts1201/hf_cache
export TORCH_HOME=/mnt/scratch/users/ts1201/torch_cache
export VLLM_USE_V1=1
export WANDB_PROJECT=kg-align-verl
# Unset ROCR_VISIBLE_DEVICES (AMD ROCm) — verl crashes if both this and
# CUDA_VISIBLE_DEVICES are set, and something in the env sets it spuriously
unset ROCR_VISIBLE_DEVICES 2>/dev/null || true

REWARD_TYPE=${REWARD_TYPE:-verifiable}
EXPERIMENT_NAME=${EXPERIMENT_NAME:-E3v2}
KG_PORT=8001

mkdir -p logs

echo "=== verl GRPO Training ==="
echo "Date: $(date)"
echo "Node: $(hostname)"
echo "GPU: $(nvidia-smi --query-gpu=name --format=csv,noheader)"
echo "Reward type: $REWARD_TYPE"
echo "Experiment: $EXPERIMENT_NAME"
echo ""

# --- Start KG server as background process ---
echo "Starting KG server on localhost:$KG_PORT ..."
python src_verl/kg_server/server.py \
    --kg conceptnet \
    --assertions_path data/raw/conceptnet-assertions-5.7.0.csv.gz \
    --port "$KG_PORT" \
    --host 0.0.0.0 &
KG_SERVER_PID=$!

# Wait for server to be ready (first run: ~80s CSV parse + graph build;
# subsequent runs: <5s from pickle cache)
echo "Waiting for KG server (PID $KG_SERVER_PID) to start..."
for i in $(seq 1 150); do
    if curl -s "http://localhost:$KG_PORT/health" > /dev/null 2>&1; then
        echo "KG server ready after $((i * 2))s"
        break
    fi
    if ! kill -0 $KG_SERVER_PID 2>/dev/null; then
        echo "ERROR: KG server process died"
        exit 1
    fi
    sleep 2
done

# Final check
if ! curl -s "http://localhost:$KG_PORT/health" > /dev/null 2>&1; then
    echo "ERROR: KG server did not start within 300s"
    kill $KG_SERVER_PID 2>/dev/null
    exit 1
fi

curl -s "http://localhost:$KG_PORT/health" | python -m json.tool
echo ""

# --- Run GRPO training ---
echo "Starting GRPO training..."
python3 -m verl.trainer.main_ppo \
    --config-path="$PWD/configs_verl" \
    --config-name='grpo_conceptnet_1.5b' \
    trainer.experiment_name="grpo-conceptnet-1.5b-${EXPERIMENT_NAME}-${REWARD_TYPE}" \
    data.train_files="['data/processed/verl_conceptnet/train.parquet']" \
    data.return_raw_chat=true \
    actor_rollout_ref.model.path="outputs/verl-sft-merged" \
    actor_rollout_ref.rollout.multi_turn.tool_config_path="configs_verl/kg_tool_config.yaml" \
    trainer.n_gpus_per_node=1 \
    data.dataloader_num_workers=0
TRAIN_EXIT=$?

# --- Cleanup: stop KG server ---
echo "Stopping KG server (PID $KG_SERVER_PID)..."
kill $KG_SERVER_PID 2>/dev/null
wait $KG_SERVER_PID 2>/dev/null || true

echo ""
echo "=== GRPO Training Complete (exit code: $TRAIN_EXIT) ==="
echo "End: $(date)"
exit $TRAIN_EXIT
