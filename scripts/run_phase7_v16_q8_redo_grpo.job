#!/usr/bin/env bash
#SBATCH --job-name=p7_v16q8r_grpo
#SBATCH --nodes=1
#SBATCH --gpus=4
#SBATCH --time=24:00:00
#SBATCH --output=logs/%x-%j.log
#SBATCH --error=logs/%x-%j.err
#SBATCH --partition=workq

# V16-Q8-REDO Phase 3: GRPO on the bug-fixed Q8 synthetic-schema corpus.
#
# Recipe = I-Self (run_grpo_cwq_39i_self.job) but with:
#   - INIT_BASE = outputs/verl-sft-cwq-7b-q8-redo-merged          (Phase 2 SFT output)
#   - REWARD_TYPE = tool_type_bonus_retrieval_contrib             (I-Self reward)
#   - kl_loss_coef = 0.25                                          (I-Self setting; NOT 0.05)
#   - optim.lr     = 3e-7                                          (I-Self)
#   - total_training_steps = 400
#   - data points to data/freebase/verl_cwq_q8_redo/{train,val}.parquet
#   - KG server runs the q8_synthetic adapter on the new entity_mapping.json
#
# Hydra override notes: any key already declared in the dataclass / yaml uses
# `++` to allow overwrite; brand-new keys use `+`.
# Do NOT add `+actor_rollout_ref.rollout.seed=...` — the dataclass rejects it.

set -eo pipefail

source "$HOME/miniforge3/bin/activate"
conda activate kg_verl
module load cudatoolkit 2>/dev/null || true
module load gcc-native/14.2 2>/dev/null || true
module load brics/nccl 2>/dev/null || true

export CC=gcc CXX=g++
export LIBRARY_PATH=/opt/nvidia/hpc_sdk/Linux_aarch64/24.11/REDIST/math_libs/12.6/targets/sbsa-linux/lib:${LIBRARY_PATH:-}
export TRITON_CACHE_DIR=/scratch/u6gg/ts1201.u6gg/.triton
export HF_HOME=/scratch/u6gg/ts1201.u6gg/hf_cache
export PYTHONUNBUFFERED=1
export VLLM_USE_V1=1
export RAY_DEDUP_LOGS=1
export RAY_TMPDIR="/tmp/ray-${SLURM_JOB_ID}"
mkdir -p "$RAY_TMPDIR"

cd "$SLURM_SUBMIT_DIR"
export PYTHONPATH="$PWD:${PYTHONPATH:-}"

SEED=42
export REWARD_TYPE=tool_type_bonus_retrieval_contrib
INIT_BASE="outputs/verl-sft-cwq-7b-q8-redo-merged"
EXPERIMENT_NAME="grpo-cwq-7b-q8-redo-20260507"
TRAIN_PARQUET="data/freebase/verl_cwq_q8_redo/train.parquet"
VAL_PARQUET="data/freebase/verl_cwq_q8_redo/val.parquet"
Q8_MAPPING="data/freebase/verl_cwq_q8_redo/entity_mapping.json"
KG_PORT=$((19300 + SLURM_JOB_ID % 100))

echo "=== V16-Q8-REDO GRPO seed=${SEED} (4x GH200) ==="
echo "Date: $(date)"
echo "Reward: $REWARD_TYPE (I-Self)"
echo "KL coef: 0.25  |  LR: 3e-7  |  Total steps: 400"
echo "Experiment: $EXPERIMENT_NAME"
echo "Init: $INIT_BASE"
echo "Train: $TRAIN_PARQUET  |  Val: $VAL_PARQUET"
echo "Q8 mapping: $Q8_MAPPING"
echo "KG port: $KG_PORT"

[ -d "$INIT_BASE" ] || { echo "ERROR: init base not found at $INIT_BASE"; exit 1; }
[ -f "$TRAIN_PARQUET" ] || { echo "ERROR: train parquet not found at $TRAIN_PARQUET"; exit 1; }
[ -f "$VAL_PARQUET" ] || { echo "ERROR: val parquet not found at $VAL_PARQUET"; exit 1; }
[ -f "$Q8_MAPPING" ] || { echo "ERROR: q8 mapping not found at $Q8_MAPPING"; exit 1; }

# KG server (q8_synthetic mode, per-job port)
python -m src_verl.kg_server.server \
    --kg q8_synthetic \
    --freebase_dir data/freebase/kg \
    --q8_mapping_path "$Q8_MAPPING" \
    --port $KG_PORT \
    --log-level warning &
KG_PID=$!
TOOL_CFG="configs_verl/kg_tool_config_freebase_${SLURM_JOB_ID}.yaml"
trap 'kill $KG_PID 2>/dev/null; rm -f "$TOOL_CFG" 2>/dev/null' EXIT
sleep 30
for i in $(seq 1 12); do
    curl -s -o /dev/null -w "%{http_code}" http://localhost:$KG_PORT/health 2>/dev/null | grep -q "200" && break
    sleep 10
done
echo "KG server (q8_synthetic) ready on port $KG_PORT"

# Per-job tool config (rewrite kg_server_url to our port)
sed "s|http://localhost:18901|http://localhost:${KG_PORT}|" \
    configs_verl/kg_tool_config_freebase.yaml > "$TOOL_CFG"

ray stop 2>/dev/null || true

python -m verl.trainer.main_ppo \
    --config-path="$PWD/configs_verl" \
    --config-name=grpo_cwq_7b \
    trainer.experiment_name="$EXPERIMENT_NAME" \
    trainer.total_training_steps=400 \
    data.train_files=["$TRAIN_PARQUET"] \
    data.val_files=["$VAL_PARQUET"] \
    actor_rollout_ref.model.path="$INIT_BASE" \
    actor_rollout_ref.actor.use_kl_loss=true \
    ++actor_rollout_ref.actor.kl_loss_coef=0.25 \
    actor_rollout_ref.actor.kl_loss_type=low_var_kl \
    actor_rollout_ref.actor.optim.lr=3e-7 \
    actor_rollout_ref.actor.data_loader_seed=$SEED \
    ++data.seed=$SEED \
    ++critic.data_loader_seed=$SEED \
    +actor_rollout_ref.rollout.enable_sleep_mode=true \
    actor_rollout_ref.rollout.agent.default_agent_loop=tool_agent \
    actor_rollout_ref.rollout.multi_turn.tool_config_path="$TOOL_CFG" \
    data.dataloader_num_workers=0

kill $KG_PID 2>/dev/null
echo "=== Done: $(date) ==="
