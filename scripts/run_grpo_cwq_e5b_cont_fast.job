#!/usr/bin/env bash
#SBATCH --job-name=grpo_e5b
#SBATCH --nodes=1
#SBATCH --gpus=4
#SBATCH --time=24:00:00
#SBATCH --output=logs/%x-%j.log
#SBATCH --error=logs/%x-%j.err
#SBATCH --partition=workq

# E5b continuation (FAST) — auto-resumes from latest checkpoint
# Speedups applied via command-line overrides ONLY (base config unchanged):
#   - n: 8 -> 4 (halve rollouts per prompt, ~2x faster)
#   - max_assistant_turns: 5 -> 3 (cap sequential depth, ~20-40% faster)
#   - gpu_memory_utilization: 0.4 -> 0.7 (more KV cache)
#   - over_sample_rate: 0.1 (trim slowest 10%)
#   - agent.num_workers: 16 (double async concurrency)

set -eo pipefail

source "$HOME/miniforge3/bin/activate"
conda activate kg_verl
module load cudatoolkit 2>/dev/null || true
module load gcc-native/14.2 2>/dev/null || true
module load brics/nccl 2>/dev/null || true

export CC=gcc CXX=g++
export LIBRARY_PATH=/opt/nvidia/hpc_sdk/Linux_aarch64/24.11/REDIST/math_libs/12.6/targets/sbsa-linux/lib:${LIBRARY_PATH:-}
export TRITON_CACHE_DIR=/scratch/u6gg/ts1201.u6gg/.triton
export HF_HOME=/scratch/u6gg/ts1201.u6gg/hf_cache
export PYTHONUNBUFFERED=1
export VLLM_USE_V1=1
export RAY_DEDUP_LOGS=1
export RAY_TMPDIR="/tmp/ray-${SLURM_JOB_ID}"
mkdir -p "$RAY_TMPDIR"

cd "$SLURM_SUBMIT_DIR"
export PYTHONPATH="$PWD:${PYTHONPATH:-}"

export REWARD_TYPE=tool_type_bonus
EXPERIMENT_NAME="grpo-cwq-7b-tool-type-bonus-20260326"

# Find latest checkpoint
CKPT_DIR="checkpoints/kg-align-verl/${EXPERIMENT_NAME}"
LATEST_STEP=$(ls "$CKPT_DIR" 2>/dev/null | grep global_step | sed 's/global_step_//' | sort -n | tail -1)

echo "=== E5b CONTINUATION (FAST: n=4, max_turns=3) ==="
echo "Date: $(date)"
echo "Node: $(hostname)"
echo "Resuming from step: $LATEST_STEP"
echo ""

# Strip optimizer from old checkpoints to save space
for d in "$CKPT_DIR"/global_step_*/actor; do
    step=$(basename $(dirname "$d") | sed 's/global_step_//')
    if [ "$step" != "$LATEST_STEP" ]; then
        count=$(find "$d" -name 'optim_world_size_*.pt' 2>/dev/null | wc -l)
        if [ "$count" -gt 0 ]; then
            rm -f "$d"/optim_world_size_*.pt
            echo "Stripped optim from step $step"
        fi
    fi
done

python -m src_verl.kg_server.server \
    --kg freebase --freebase_dir data/freebase/kg --port 18901 --log-level warning > /dev/null 2>&1 &
KG_PID=$!
sleep 30
for i in $(seq 1 12); do
    curl -s -o /dev/null -w "%{http_code}" http://localhost:18901/health 2>/dev/null | grep -q "200" && echo "KG healthy" && break
    sleep 10
done
echo ""

ray stop 2>/dev/null || true

echo "=== Launching GRPO (resume_mode=auto) ==="
echo "Start: $(date)"
START_TIME=$(date +%s)

set +e
python -m verl.trainer.main_ppo \
    --config-path="$PWD/configs_verl" \
    --config-name=grpo_cwq_7b \
    trainer.experiment_name="$EXPERIMENT_NAME" \
    trainer.resume_mode=auto \
    +actor_rollout_ref.rollout.enable_sleep_mode=true \
    actor_rollout_ref.rollout.agent.default_agent_loop=tool_agent \
    actor_rollout_ref.rollout.gpu_memory_utilization=0.7 \
    actor_rollout_ref.rollout.n=4 \
    ++actor_rollout_ref.rollout.over_sample_rate=0.1 \
    ++actor_rollout_ref.rollout.agent.num_workers=16 \
    data.dataloader_num_workers=0
GRPO_EXIT=$?
set -e

END_TIME=$(date +%s)
ELAPSED=$((END_TIME - START_TIME))

echo ""
echo "=== Results ==="
echo "Exit code: $GRPO_EXIT"
echo "Total time: ${ELAPSED}s ($((ELAPSED / 60))m)"
echo "Checkpoints:"
ls "$CKPT_DIR" 2>/dev/null | grep global_step | sort -t_ -k3 -n

kill $KG_PID 2>/dev/null
echo "=== Done ==="
