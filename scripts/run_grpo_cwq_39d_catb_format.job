#!/usr/bin/env bash
#SBATCH --job-name=grpo_39d
#SBATCH --nodes=1
#SBATCH --gpus=4
#SBATCH --time=24:00:00
#SBATCH --output=logs/%x-%j.log
#SBATCH --error=logs/%x-%j.err
#SBATCH --partition=workq

# Task 39D: Cat-B filtered + format reward
#
# Same as 39A (format reward, R = 0.25*r_outcome + 0.60*r_tool_type + 0.15*r_format)
# but trains ONLY on Category B questions (18,833 questions where pass@10=0).
# Init from original SFT (NOT enhanced SFT — that's variant E).
#
# Hypothesis: removing Cat A "free" rewards forces tool exploration. Combined with
# format reward, the discovered behavior should be stable.

set -eo pipefail

source "$HOME/miniforge3/bin/activate"
conda activate kg_verl
module load cudatoolkit 2>/dev/null || true
module load gcc-native/14.2 2>/dev/null || true
module load brics/nccl 2>/dev/null || true

export CC=gcc CXX=g++
export LIBRARY_PATH=/opt/nvidia/hpc_sdk/Linux_aarch64/24.11/REDIST/math_libs/12.6/targets/sbsa-linux/lib:${LIBRARY_PATH:-}
export TRITON_CACHE_DIR=/scratch/u6gg/ts1201.u6gg/.triton
export HF_HOME=/scratch/u6gg/ts1201.u6gg/hf_cache
export PYTHONUNBUFFERED=1
export VLLM_USE_V1=1
export RAY_DEDUP_LOGS=1
export RAY_TMPDIR="/tmp/ray-${SLURM_JOB_ID}"
mkdir -p "$RAY_TMPDIR"

cd "$SLURM_SUBMIT_DIR"
export PYTHONPATH="$PWD:${PYTHONPATH:-}"

export REWARD_TYPE=tool_type_bonus_format
EXPERIMENT_NAME="grpo-cwq-7b-39d-catb-format-20260413"
INIT_BASE="outputs/verl-sft-cwq-7b-merged"
TRAIN_FILE="data/freebase/verl_cwq/train_category_b.parquet"

echo "=== Task 39D: Cat-B filtered + format reward (4x GH200) ==="
echo "Date: $(date)"
echo "Node: $(hostname)"
echo "Reward type: $REWARD_TYPE"
echo "Experiment: $EXPERIMENT_NAME"
echo "Init base: $INIT_BASE"
echo "Train data: $TRAIN_FILE"
echo "GPUs: $(nvidia-smi --query-gpu=name --format=csv,noheader | wc -l)x GH200"
echo ""

if [ ! -f "$TRAIN_FILE" ]; then
    echo "ERROR: train_category_b.parquet not found at $TRAIN_FILE"
    exit 1
fi

python -m src_verl.kg_server.server \
    --kg freebase --freebase_dir data/freebase/kg --port 18901 --log-level warning > /dev/null 2>&1 &
KG_PID=$!
trap 'kill $KG_PID 2>/dev/null' EXIT

echo "Waiting for KG server..."
sleep 30
for i in $(seq 1 12); do
    if curl -s -o /dev/null -w "%{http_code}" http://localhost:18901/health 2>/dev/null | grep -q "200"; then
        echo "KG server healthy"
        break
    fi
    sleep 10
done
echo ""

ray stop 2>/dev/null || true

echo "=== Launching GRPO (39D) ==="
START_TIME=$(date +%s)

set +e
python -m verl.trainer.main_ppo \
    --config-path="$PWD/configs_verl" \
    --config-name=grpo_cwq_7b \
    trainer.experiment_name="$EXPERIMENT_NAME" \
    actor_rollout_ref.model.path="$INIT_BASE" \
    "data.train_files=[$TRAIN_FILE]" \
    +actor_rollout_ref.rollout.enable_sleep_mode=true \
    actor_rollout_ref.rollout.agent.default_agent_loop=tool_agent \
    data.dataloader_num_workers=0
GRPO_EXIT=$?
set -e

END_TIME=$(date +%s)
ELAPSED=$((END_TIME - START_TIME))

echo ""
echo "=== Results ==="
echo "Exit code: $GRPO_EXIT"
echo "Total time: ${ELAPSED}s ($((ELAPSED / 60))m)"
ls /projects/u6gg/KG_GRPO/checkpoints/kg-align-verl/${EXPERIMENT_NAME}/ 2>/dev/null | grep global_step | sort -t_ -k3 -n
echo "End: $(date)"
