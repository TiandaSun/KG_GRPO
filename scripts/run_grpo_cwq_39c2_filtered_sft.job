#!/usr/bin/env bash
#SBATCH --job-name=grpo_39c2
#SBATCH --nodes=1
#SBATCH --gpus=4
#SBATCH --time=24:00:00
#SBATCH --output=logs/%x-%j.log
#SBATCH --error=logs/%x-%j.err
#SBATCH --partition=workq

# Task 39C2-data: E5b-stabilized via SFT Replay (filtered correct-via-tool data)
#
# Same orchestration as C1, but SFT replay uses the 1,293 "correct-via-tool"
# trajectories (25.9% of original 5K) instead of the full mixed set.
#
# Hypothesis vs C1: Higher-quality SFT reminders (where the gold answer actually
# appears in a tool response) produce better-calibrated retrieval behavior than
# mixed-quality reminders that teach "pantomime" (answer hallucinated after tools).
#
# SFT data: data/freebase/sft_trajectories_correct_via_tool.jsonl (1,293 samples)
# Generated by: scripts/filter_sft_trajectories.py

set -eo pipefail

source "$HOME/miniforge3/bin/activate"
conda activate kg_verl
module load cudatoolkit 2>/dev/null || true
module load gcc-native/14.2 2>/dev/null || true
module load brics/nccl 2>/dev/null || true

export CC=gcc CXX=g++
export LIBRARY_PATH=/opt/nvidia/hpc_sdk/Linux_aarch64/24.11/REDIST/math_libs/12.6/targets/sbsa-linux/lib:${LIBRARY_PATH:-}
export TRITON_CACHE_DIR=/scratch/u6gg/ts1201.u6gg/.triton
export HF_HOME=/scratch/u6gg/ts1201.u6gg/hf_cache
export PYTHONUNBUFFERED=1
export VLLM_USE_V1=1
export RAY_DEDUP_LOGS=1
export RAY_TMPDIR="/tmp/ray-${SLURM_JOB_ID}"
mkdir -p "$RAY_TMPDIR"

cd "$SLURM_SUBMIT_DIR"
export PYTHONPATH="$PWD:${PYTHONPATH:-}"

export REWARD_TYPE=tool_type_bonus
RUN_TAG="grpo-cwq-7b-39c2-filtered-sft-20260413"
CKPT_ROOT="/projects/u6gg/KG_GRPO/checkpoints/kg-align-verl"
OUTPUTS_ROOT="outputs/39c2"
SFT_DATA="data/freebase/sft_trajectories_correct_via_tool.jsonl"

mkdir -p "$OUTPUTS_ROOT"

# Verify filtered SFT data exists
if [ ! -f "$SFT_DATA" ]; then
    echo "ERROR: filtered SFT data not found at $SFT_DATA"
    echo "Run: python scripts/filter_sft_trajectories.py"
    exit 1
fi
echo "Filtered SFT data: $(wc -l < "$SFT_DATA") trajectories"

INITIAL_BASE="outputs/verl-sft-cwq-7b-merged"
STEPS_PER_CYCLE=50
MAX_CYCLES=5
SFT_EPOCHS=1

# Find the last completed cycle (for resume on timeout)
LAST_CYCLE=0
for C in $(seq "$MAX_CYCLES" -1 1); do
    if [ -d "$OUTPUTS_ROOT/cycle${C}_model" ] && [ -f "$OUTPUTS_ROOT/cycle${C}_model/config.json" ]; then
        LAST_CYCLE=$C
        break
    fi
done

if [ "$LAST_CYCLE" -gt 0 ]; then
    BASE="$OUTPUTS_ROOT/cycle${LAST_CYCLE}_model"
    echo "=== Resuming from cycle $LAST_CYCLE: base = $BASE ==="
else
    BASE="$INITIAL_BASE"
    echo "=== Fresh start: base = $BASE ==="
fi

# Start KG server once
python -m src_verl.kg_server.server \
    --kg freebase --freebase_dir data/freebase/kg --port 18901 --log-level warning > /dev/null 2>&1 &
KG_PID=$!
trap 'kill $KG_PID 2>/dev/null' EXIT

echo "Waiting for KG server..."
sleep 30
for i in $(seq 1 12); do
    if curl -s -o /dev/null -w "%{http_code}" http://localhost:18901/health 2>/dev/null | grep -q "200"; then
        echo "KG server healthy"
        break
    fi
    sleep 10
done
echo ""

for CYCLE in $(seq $((LAST_CYCLE + 1)) "$MAX_CYCLES"); do
    STEP_END=$((CYCLE * STEPS_PER_CYCLE))
    EXPERIMENT="${RUN_TAG}-c${CYCLE}"
    CKPT_DIR="$CKPT_ROOT/$EXPERIMENT"
    HF_CKPT="$OUTPUTS_ROOT/cycle${CYCLE}_hf"
    LORA_DIR="$OUTPUTS_ROOT/cycle${CYCLE}_lora"
    NEXT_BASE="$OUTPUTS_ROOT/cycle${CYCLE}_model"

    echo ""
    echo "========================================"
    echo "CYCLE $CYCLE / $MAX_CYCLES"
    echo "  BASE: $BASE"
    echo "  Experiment: $EXPERIMENT"
    echo "  SFT data: $SFT_DATA ($(wc -l < "$SFT_DATA") samples, filtered correct-via-tool)"
    echo "  Start: $(date)"
    echo "========================================"

    echo ""
    echo "--- [C${CYCLE}] Step 1: GRPO ${STEPS_PER_CYCLE} steps ---"
    ray stop 2>/dev/null || true
    set +e
    python -m verl.trainer.main_ppo \
        --config-path="$PWD/configs_verl" \
        --config-name=grpo_cwq_7b \
        trainer.experiment_name="$EXPERIMENT" \
        trainer.total_training_steps=$STEPS_PER_CYCLE \
        actor_rollout_ref.model.path="$BASE" \
        +actor_rollout_ref.rollout.enable_sleep_mode=true \
        actor_rollout_ref.rollout.agent.default_agent_loop=tool_agent \
        data.dataloader_num_workers=0
    GRPO_EXIT=$?
    set -e
    if [ "$GRPO_EXIT" -ne 0 ]; then
        echo "GRPO failed at cycle $CYCLE (exit=$GRPO_EXIT)"
        exit 1
    fi

    GRPO_CKPT="$CKPT_DIR/global_step_${STEPS_PER_CYCLE}/actor"
    if [ ! -d "$GRPO_CKPT" ]; then
        echo "ERROR: expected GRPO checkpoint not found at $GRPO_CKPT"
        ls -la "$CKPT_DIR/" 2>&1
        exit 1
    fi

    echo ""
    echo "--- [C${CYCLE}] Step 2: FSDP → HF merge ---"
    mkdir -p "$HF_CKPT"
    python -m verl.model_merger merge \
        --backend fsdp \
        --local_dir "$GRPO_CKPT" \
        --target_dir "$HF_CKPT"
    if [ ! -f "$HF_CKPT/tokenizer.json" ]; then
        cp -n "$BASE"/tokenizer* "$HF_CKPT/" 2>/dev/null || true
        cp -n "$BASE"/chat_template.jinja "$HF_CKPT/" 2>/dev/null || true
    fi

    echo ""
    echo "--- [C${CYCLE}] Step 3: SFT ${SFT_EPOCHS} epoch on FILTERED data ---"
    python src_verl/training/sft_multiturn.py \
        --config configs_verl/sft_cwq.yaml \
        --model_path "$HF_CKPT" \
        --output_dir "$LORA_DIR" \
        --num_train_epochs "$SFT_EPOCHS" \
        --train_file "$SFT_DATA"

    echo ""
    echo "--- [C${CYCLE}] Step 4: Merge LoRA → $NEXT_BASE ---"
    python scripts/merge_sft_adapter.py \
        --base_model "$HF_CKPT" \
        --adapter_path "$LORA_DIR" \
        --output_path "$NEXT_BASE"

    cp -n "$HF_CKPT"/tokenizer* "$NEXT_BASE/" 2>/dev/null || true
    cp -n "$HF_CKPT"/chat_template.jinja "$NEXT_BASE/" 2>/dev/null || true

    rm -rf "$HF_CKPT" "$LORA_DIR" 2>/dev/null || true

    BASE="$NEXT_BASE"
    echo ""
    echo "--- [C${CYCLE}] DONE at $(date). Next base: $BASE ---"
done

echo ""
echo "=== All cycles complete: $(date) ==="
echo "Final base: $BASE"
