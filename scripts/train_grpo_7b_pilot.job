#!/usr/bin/env bash
#SBATCH --job-name=kg_grpo_7b_pilot
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=8
#SBATCH --mem=64G
#SBATCH --time=01:00:00
#SBATCH --account=cs-ontrel-2021
#SBATCH --mail-type=END,FAIL
#SBATCH --mail-user=tianda.sun@york.ac.uk
#SBATCH --output=logs_archive/%x-%j.log
#SBATCH --error=logs_archive/%x-%j.err
#SBATCH --partition=gpuplus
#SBATCH --gpus-per-node=1

# Pilot: 10-step GRPO on 7B to verify vLLM colocate works
# Tests VRAM and measures step time on 1x H100.

set -eo pipefail

# --- Environment Setup ---
module load Miniconda3
module load CUDA/12.1.1
source activate kg_align

export HF_HOME=/mnt/scratch/users/ts1201/hf_cache
export TORCH_HOME=/mnt/scratch/users/ts1201/torch_cache
export WANDB_PROJECT=kg-align-rl

cd /mnt/scratch/users/ts1201/KG_lora
export PYTHONPATH=/mnt/scratch/users/ts1201/KG_lora:${PYTHONPATH:-}

# Ensure vLLM is installed (needed for colocate mode)
python -c "import vllm; print(f'vLLM {vllm.__version__} available')" 2>/dev/null || {
    echo "vLLM not found, installing..."
    pip install vllm --quiet
}

echo "=== GRPO 7B Pilot (10 steps) ==="
echo "Date: $(date)"
echo "Node: $(hostname)"
nvidia-smi --query-gpu=index,name,memory.total --format=csv,noheader 2>/dev/null
echo ""

# Single process — vLLM colocate TP=1 on 1x H100.
python src/training/train_grpo.py \
    --config configs/grpo_7b.yaml \
    --output_dir outputs/grpo-7b-pilot \
    --pilot_steps 10

echo ""
echo "=== Pilot Complete ==="
echo "End: $(date)"
nvidia-smi
