#!/usr/bin/env bash
#SBATCH --job-name=e2_diag2
#SBATCH --nodes=1
#SBATCH --gpus=4
#SBATCH --time=02:00:00
#SBATCH --output=logs/%x-%j.log
#SBATCH --error=logs/%x-%j.err
#SBATCH --partition=workq

# DIAGNOSTIC 2: Test if checkpoint SAVE causes the hang
# Change: save_freq=200 (skip the step-50 save entirely)
# If training passes step 50 without saving, the checkpoint save is the culprit.
# Also test_freq=200 to skip validation at step 50.

set -eo pipefail

source "$HOME/miniforge3/bin/activate"
conda activate kg_verl
module load cudatoolkit 2>/dev/null || true
module load gcc-native/14.2 2>/dev/null || true
module load brics/nccl 2>/dev/null || true

export CC=gcc CXX=g++
export LIBRARY_PATH=/opt/nvidia/hpc_sdk/Linux_aarch64/24.11/REDIST/math_libs/12.6/targets/sbsa-linux/lib:${LIBRARY_PATH:-}
export TRITON_CACHE_DIR=/scratch/u6gg/ts1201.u6gg/.triton
export HF_HOME=/scratch/u6gg/ts1201.u6gg/hf_cache
export PYTHONUNBUFFERED=1
export VLLM_USE_V1=1
export RAY_DEDUP_LOGS=1
export RAY_TMPDIR="/tmp/ray-${SLURM_JOB_ID}"
mkdir -p "$RAY_TMPDIR"

cd "$SLURM_SUBMIT_DIR"
export PYTHONPATH="$PWD:${PYTHONPATH:-}"

export REWARD_TYPE=heuristic
EXPERIMENT_NAME="grpo-cwq-7b-heuristic-diag2-saveat200"

echo "=== E2 DIAG 2: save_freq=200, test_freq=200 ==="
echo "Date: $(date)"
echo "Node: $(hostname)"
echo "Purpose: Test if checkpoint save at step 50 causes the hang"
echo "GPUs: $(nvidia-smi --query-gpu=name --format=csv,noheader | wc -l)x GH200"
echo ""

# --- Start KG server ---
python -m src_verl.kg_server.server \
    --kg freebase \
    --freebase_dir data/freebase/kg \
    --port 18901 \
    --log-level warning > /dev/null 2>&1 &
KG_PID=$!

sleep 30
for i in $(seq 1 12); do
    if curl -s -o /dev/null -w "%{http_code}" http://localhost:18901/health 2>/dev/null | grep -q "200"; then
        echo "KG server healthy"
        break
    fi
    sleep 10
done
echo ""

ray stop 2>/dev/null || true

echo "=== Launching GRPO (save_freq=200) ==="
echo "Start: $(date)"

set +e
python -m verl.trainer.main_ppo \
    --config-path="$PWD/configs_verl" \
    --config-name=grpo_cwq_7b \
    trainer.experiment_name="$EXPERIMENT_NAME" \
    trainer.save_freq=200 \
    trainer.test_freq=200 \
    +actor_rollout_ref.rollout.enable_sleep_mode=true \
    actor_rollout_ref.rollout.agent.default_agent_loop=tool_agent \
    data.dataloader_num_workers=0
GRPO_EXIT=$?
set -e

echo ""
echo "=== DIAGNOSTIC 2 RESULTS ==="
echo "Exit code: $GRPO_EXIT"
STEPS_DONE=$(grep -c "Training Progress" logs/e2_diag2-${SLURM_JOB_ID}.err 2>/dev/null || echo "?")
echo "Steps completed: $STEPS_DONE"
echo "Checkpoints:"
ls checkpoints/kg-align-verl/${EXPERIMENT_NAME}/ 2>/dev/null | grep global_step

if [ "$STEPS_DONE" -gt 55 ]; then
    echo ">>> PASSED step 50 without checkpoint save — save is the trigger!"
else
    echo ">>> Still hung at step 50 — not the checkpoint save"
fi

kill $KG_PID 2>/dev/null
echo "=== Done ==="
