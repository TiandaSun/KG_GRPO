#!/usr/bin/env bash
#SBATCH --job-name=p7_v16_q8_redo_rewrite
#SBATCH --nodes=1
#SBATCH --gpus=0
#SBATCH --cpus-per-task=4
#SBATCH --time=01:00:00
#SBATCH --output=logs/%x-%j.log
#SBATCH --error=logs/%x-%j.err
#SBATCH --partition=workq

# V16-Q8-REDO Phase 1: bug-fixed synthetic-schema rewrite + sanity check (CPU-only).
#
# Reads data/freebase/verl_cwq/{train,val,test}.parquet and
# data/freebase/sft_trajectories.jsonl. Writes:
#   - data/freebase/verl_cwq_q8_redo/{train,val,test}.parquet
#   - data/freebase/verl_cwq_q8_redo/entity_mapping.json
#   - data/freebase/sft_trajectories_q8_redo.jsonl
#   - results/phase7/v16_q8_redo_sanity_report.md
#
# Bug-fix highlights vs v15-Q8 (the broken one):
#   1. Per-row local entity set (not global label dict) for parquet rewrites
#   2. Whole-word regex matching with re.escape (not str.replace substring)
#   3. System prompt + tool descriptions are NEVER touched
#   4. Min-length 3 chars filter to avoid catching "I"/"a"/"of" etc.
#   5. Cross-row consistent URI hashing maintained via entity_mapping.json
#
# Sanity-check protocol (5 automated checks; sanity FAILURE -> exit 2):
#   (a) 5 random parquet rows: original vs rewritten user prompts side-by-side
#   (b) 5 random SFT trajectories side-by-side; system messages must be identical
#   (c) Mapping counts + label-length distribution
#   (d) System-prompt fingerprint preserved unchanged in rewritten SFT
#   (e) Whole-word probe on "Lou Seal": no substring matches; URI count == orig
#       whole-word count; bare "Lou Seal" no longer present
#   (f) Nested-replacement corruption scan (no "entity://...entity://" anywhere)

set -eo pipefail

source "$HOME/miniforge3/bin/activate"
conda activate kg_verl

export PYTHONUNBUFFERED=1
export TMPDIR="/tmp"

cd "$SLURM_SUBMIT_DIR"
export PYTHONPATH="$PWD:${PYTHONPATH:-}"

echo "=== V16-Q8-REDO Phase 1 (rewrite + sanity check, CPU only) ==="
echo "Date: $(date)"
echo "Working dir: $PWD"
echo "Hostname: $(hostname)"

mkdir -p data/freebase/verl_cwq_q8_redo
mkdir -p results/phase7
mkdir -p logs

# Pre-flight: AST-validate the script before consuming compute
python -c 'import ast; ast.parse(open("scripts/task_v16_q8_redo_rewrite.py").read())'
echo "AST validation passed."

echo ""
echo "=== Running rewriter + sanity-check (single CLI invocation) ==="
python scripts/task_v16_q8_redo_rewrite.py \
    --input_dir data/freebase/verl_cwq \
    --output_dir data/freebase/verl_cwq_q8_redo \
    --sft_input data/freebase/sft_trajectories.jsonl \
    --sft_output data/freebase/sft_trajectories_q8_redo.jsonl \
    --report_path results/phase7/v16_q8_redo_sanity_report.md

echo ""
echo "=== Output listing ==="
ls -la data/freebase/verl_cwq_q8_redo/
ls -la data/freebase/sft_trajectories_q8_redo.jsonl
ls -la results/phase7/v16_q8_redo_sanity_report.md

echo ""
echo "=== Sanity report HEAD ==="
head -80 results/phase7/v16_q8_redo_sanity_report.md

echo ""
echo "=== Sanity report TAIL (overall verdict) ==="
tail -10 results/phase7/v16_q8_redo_sanity_report.md

echo ""
echo "=== Done: $(date) ==="
