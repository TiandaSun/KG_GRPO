#!/usr/bin/env bash
#SBATCH --job-name=p7_v15_q8_sft
#SBATCH --nodes=1
#SBATCH --gpus=4
#SBATCH --time=12:00:00
#SBATCH --output=logs/%x-%j.log
#SBATCH --error=logs/%x-%j.err
#SBATCH --partition=workq

# V15-Q8 Lane 8 step 2: rule-SFT on synthetic-schema trajectories.
#
# Same recipe as scripts/run_phase7_s02_g2_sft_seed.job (G2 SFT pattern):
#   - Init from base Qwen2.5-7B-Instruct (sft_cwq.yaml default)
#   - Train file: data/freebase/sft_trajectories_q8_synthetic.jsonl (~5K traces, rewritten)
#   - 1 epoch, LoRA + merge
#   - SEED=42 (single seed for Q8 lane)
#
# Output: outputs/verl-sft-cwq-7b-q8-synthetic-merged

set -eo pipefail

source "$HOME/miniforge3/bin/activate"
conda activate kg_verl
module load cudatoolkit 2>/dev/null || true
module load gcc-native/14.2 2>/dev/null || true

export CC=gcc CXX=g++
export LIBRARY_PATH=/opt/nvidia/hpc_sdk/Linux_aarch64/24.11/REDIST/math_libs/12.6/targets/sbsa-linux/lib:${LIBRARY_PATH:-}
export TRITON_CACHE_DIR=/scratch/u6gg/ts1201.u6gg/.triton
export HF_HOME=/scratch/u6gg/ts1201.u6gg/hf_cache
export PYTHONUNBUFFERED=1
export TMPDIR="/tmp"

cd "$SLURM_SUBMIT_DIR"
export PYTHONPATH="$PWD:${PYTHONPATH:-}"

SEED=42
TRAIN_FILE="data/freebase/sft_trajectories_q8_synthetic.jsonl"
OUTPUT_DIR="outputs/verl-sft-cwq-7b-q8-synthetic-seed${SEED}"
MERGED_DIR="outputs/verl-sft-cwq-7b-q8-synthetic-merged"
WANDB_RUN="sft-cwq-7b-q8-synthetic-20260506"

# Model_name from configs_verl/sft_cwq.yaml: Qwen/Qwen2.5-7B-Instruct (uses HF cache)
INIT_BASE="Qwen/Qwen2.5-7B-Instruct"

echo "=== V15-Q8 SFT (4x GH200) ==="
echo "Date: $(date)"
echo "Init base: $INIT_BASE"
echo "Train: $TRAIN_FILE"
echo "Output (LoRA): $OUTPUT_DIR"
echo "Merged: $MERGED_DIR"
echo "Seed: $SEED"

[ -f "$TRAIN_FILE" ] || { echo "ERROR: $TRAIN_FILE not found"; exit 1; }
TRAIN_LINES=$(wc -l < "$TRAIN_FILE")
echo "Trajectories in $TRAIN_FILE: $TRAIN_LINES (expected ~5000)"

python src_verl/training/sft_multiturn.py \
    --config configs_verl/sft_cwq.yaml \
    --output_dir "$OUTPUT_DIR" \
    --num_train_epochs 1 \
    --train_file "$TRAIN_FILE" \
    --seed "$SEED" \
    --wandb_run_name "$WANDB_RUN"

echo ""
echo "=== Merge LoRA adapter ==="
python scripts/merge_sft_adapter.py \
    --base_model "$INIT_BASE" \
    --adapter_path "$OUTPUT_DIR" \
    --output_path "$MERGED_DIR"

# Copy tokenizer + chat template (same pattern as G2 SFT)
HF_BASE_LOCAL="${HF_HOME}/hub/models--Qwen--Qwen2.5-7B-Instruct/snapshots"
if [ -d "$HF_BASE_LOCAL" ]; then
    SNAP=$(ls "$HF_BASE_LOCAL" | head -1)
    cp -n "$HF_BASE_LOCAL/$SNAP"/tokenizer* "$MERGED_DIR/" 2>/dev/null || true
    cp -n "$HF_BASE_LOCAL/$SNAP"/chat_template.jinja "$MERGED_DIR/" 2>/dev/null || true
fi

echo ""
echo "=== Done: $(date) ==="
echo "Merged checkpoint: $MERGED_DIR"
ls -la "$MERGED_DIR" | head -20
