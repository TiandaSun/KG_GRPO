#!/usr/bin/env bash
#SBATCH --job-name=kg_sft_7b
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=8
#SBATCH --mem=64G
#SBATCH --time=04:00:00
#SBATCH --account=cs-ontrel-2021
#SBATCH --mail-type=END,FAIL
#SBATCH --mail-user=tianda.sun@york.ac.uk
#SBATCH --output=logs_archive/%x-%j.log
#SBATCH --error=logs_archive/%x-%j.err
#SBATCH --partition=gpuplus
#SBATCH --gpus-per-node=1

# Stage 4 (7B): SFT Warmup on Qwen2.5-7B-Instruct
# Estimated VRAM: ~25GB on 1x H100. Estimated runtime: ~1-2 hours.

set -eo pipefail

# --- Environment Setup ---
module load Miniconda3
module load CUDA/12.1.1
source activate kg_align

export HF_HOME=/mnt/scratch/users/ts1201/hf_cache
export TORCH_HOME=/mnt/scratch/users/ts1201/torch_cache
export WANDB_PROJECT=kg-align-rl

cd /mnt/scratch/users/ts1201/KG_lora
export PYTHONPATH=/mnt/scratch/users/ts1201/KG_lora:${PYTHONPATH:-}

echo "=== Stage 4 (7B): SFT Warmup Training ==="
echo "Date: $(date)"
echo "Node: $(hostname)"
echo "GPU: $(nvidia-smi --query-gpu=name --format=csv,noheader)"
echo ""

python src/training/sft_warmup.py --config configs/sft_7b.yaml

echo ""
echo "=== Stage 4 (7B) Complete ==="
echo "End: $(date)"
echo ""
echo "Output files:"
ls -lh outputs/sft-warmup-7b/
