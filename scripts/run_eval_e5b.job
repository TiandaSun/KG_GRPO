#!/usr/bin/env bash
#SBATCH --job-name=eval_e5b
#SBATCH --nodes=1
#SBATCH --gpus=1
#SBATCH --time=12:00:00
#SBATCH --output=logs/%x-%j.log
#SBATCH --error=logs/%x-%j.err
#SBATCH --partition=workq

# E5b (R_tool_type_bonus) evaluation — focus on collapse analysis
# Key questions:
#   1. Step 400: selective tool use or random degradation? (0.88 tool calls)
#   2. Step 700: why EM=0? empty output? fixed wrong answer? format collapse?
#   3. Step 150 vs 400: reward signal direction

set -eo pipefail

source "$HOME/miniforge3/bin/activate"
conda activate kg_verl
module load cudatoolkit 2>/dev/null || true
module load gcc-native/14.2 2>/dev/null || true

export CC=gcc CXX=g++
export HF_HOME=/scratch/u6gg/ts1201.u6gg/hf_cache
export PYTHONUNBUFFERED=1

cd "$SLURM_SUBMIT_DIR"
export PYTHONPATH="$PWD:${PYTHONPATH:-}"

# Checkpoints now on $PROJECTDIR
CKPT_DIR="/projects/u6gg/KG_GRPO/checkpoints/kg-align-verl/grpo-cwq-7b-tool-type-bonus-20260326"
TRAJ_DIR="results/trajectories/e5b_tool_type_bonus"

echo "=== E5b Evaluation (with tools) — Collapse Analysis ==="
echo "Date: $(date)"
echo "Checkpoints available:"
ls "$CKPT_DIR" | grep global_step | sort -t_ -k3 -n
echo ""

# Start KG server
echo "Starting Freebase KG server..."
python -m src_verl.kg_server.server --kg freebase --freebase_dir data/freebase/kg --port 18901 --log-level warning &
KG_PID=$!
sleep 30
for i in $(seq 1 12); do
    if curl -s -o /dev/null -w "%{http_code}" http://localhost:18901/health 2>/dev/null | grep -q "200"; then
        echo "KG server healthy after ${i}0+30 seconds"
        break
    fi
    echo "  Still loading... (${i}0+30s)"
    sleep 10
done
echo ""

mkdir -p results "$TRAJ_DIR"

# Part 1: Goodhart curve — dense checkpoints to capture collapse
echo "=== E5b Goodhart curve: steps 50,100,150,200,250,300,350,400,500,600,700 ==="
python scripts/eval_with_tools.py \
    --checkpoint_dir "$CKPT_DIR" \
    --steps 50 100 150 200 250 300 350 400 500 600 700 \
    --eval_data data/freebase/verl_cwq/val.parquet \
    --output results/eval_e5b_goodhart_curve.json \
    --kg_server_url http://localhost:18901 \
    --max_samples 500 \
    --max_turns 5
echo ""

# Part 2: Trajectories at key steps — 150 (peak), 400 (degrading), 700 (collapsed)
for step in 150 400 700; do
    echo "=== E5b trajectories: step $step ==="
    python scripts/eval_with_tools.py \
        --checkpoint_dir "$CKPT_DIR" \
        --steps "$step" \
        --eval_data data/freebase/verl_cwq/val.parquet \
        --output "results/eval_e5b_traj_${step}.json" \
        --kg_server_url http://localhost:18901 \
        --max_samples 500 \
        --max_turns 5 \
        --save_trajectories "$TRAJ_DIR" \
        --max_trajectory_samples 100
    echo ""
done

kill $KG_PID 2>/dev/null

# Part 3: Hop-stratified analysis
echo "=== Hop-stratified analysis ==="
for step in 150 400 700; do
    traj="${TRAJ_DIR}/step_${step}/trajectories.json"
    if [ -f "$traj" ]; then
        echo "--- Step $step ---"
        python scripts/eval_hop_stratified.py \
            --trajectories "$traj" \
            --output "results/hop_stratified_e5b_${step}.json"
        echo ""
    fi
done

# Part 4: Collapse analysis — detailed trajectory inspection
echo "=== E5b Collapse Analysis ==="
python3 << 'PYEOF'
import json
import re
from collections import Counter
from pathlib import Path

TRAJ_DIR = Path("results/trajectories/e5b_tool_type_bonus")

for step in [150, 400, 700]:
    traj_file = TRAJ_DIR / f"step_{step}" / "trajectories.json"
    if not traj_file.exists():
        print(f"\n--- Step {step}: file not found ---")
        continue

    trajs = json.loads(traj_file.read_text())
    print(f"\n{'='*60}")
    print(f"Step {step}: {len(trajs)} trajectories")
    print(f"{'='*60}")

    # Basic stats
    ems = [t.get("em", 0) for t in trajs]
    tool_counts = [t.get("num_tool_calls", 0) for t in trajs]
    print(f"  EM: {sum(ems)/len(ems):.3f} ({sum(1 for e in ems if e > 0)}/{len(ems)} correct)")
    print(f"  Tool calls: mean={sum(tool_counts)/len(tool_counts):.2f}, "
          f"0-calls={sum(1 for t in tool_counts if t==0)}, "
          f"1-call={sum(1 for t in tool_counts if t==1)}, "
          f"2+calls={sum(1 for t in tool_counts if t>=2)}")

    # Tool action distribution
    action_counts = Counter()
    for t in trajs:
        resp = t.get("full_response", "")
        for m in re.finditer(r"<search>\s*(\w+)\(", resp):
            action_counts[m.group(1)] += 1
    if action_counts:
        total_actions = sum(action_counts.values())
        print(f"  Tool actions ({total_actions} total):")
        for action, cnt in action_counts.most_common():
            print(f"    {action}: {cnt} ({100*cnt/total_actions:.1f}%)")

    # Output format analysis
    empty_pred = sum(1 for t in trajs if not t.get("predicted", "").strip())
    has_answer_tag = sum(1 for t in trajs
                        if "<answer>" in t.get("full_response", ""))
    pred_lengths = [len(t.get("predicted", "")) for t in trajs]
    unique_preds = len(set(t.get("predicted", "") for t in trajs))

    print(f"  Output format:")
    print(f"    Empty predictions: {empty_pred}/{len(trajs)}")
    print(f"    Has <answer> tag: {has_answer_tag}/{len(trajs)}")
    print(f"    Unique predictions: {unique_preds}/{len(trajs)}")
    print(f"    Mean pred length: {sum(pred_lengths)/len(pred_lengths):.1f} chars")

    # Response length analysis
    resp_lengths = [len(t.get("full_response", "")) for t in trajs]
    print(f"  Response length: mean={sum(resp_lengths)/len(resp_lengths):.0f}, "
          f"min={min(resp_lengths)}, max={max(resp_lengths)}")

    # Show 3 examples
    print(f"\n  --- Example trajectories ---")
    for i, t in enumerate(trajs[:3]):
        print(f"  [{i}] Q: {t.get('question', '')[:80]}")
        print(f"      Gold: {t.get('gold_answer', '')[:60]}")
        print(f"      Pred: {t.get('predicted', '')[:60]}")
        print(f"      EM={t.get('em', 0)}, tools={t.get('num_tool_calls', 0)}")
        resp_preview = t.get("full_response", "")[:200].replace("\n", " ")
        print(f"      Response: {resp_preview}")
        print()

PYEOF

echo "=== Done ==="
echo "End: $(date)"
