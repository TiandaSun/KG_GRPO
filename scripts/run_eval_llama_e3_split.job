#!/usr/bin/env bash
#SBATCH --job-name=eval_llama_e3_s
#SBATCH --nodes=1
#SBATCH --gpus=1
#SBATCH --time=10:00:00
#SBATCH --output=logs/%x-%j.log
#SBATCH --error=logs/%x-%j.err
#SBATCH --partition=workq

# Llama E3 eval — single step per job, faster settings (max_turns=3)
# Usage: sbatch --export=STEP=500 scripts/run_eval_llama_e3_split.job

set -eo pipefail

source "$HOME/miniforge3/bin/activate"
conda activate kg_verl
module load cudatoolkit 2>/dev/null || true
module load gcc-native/14.2 2>/dev/null || true

export CC=gcc CXX=g++
export HF_HOME=/scratch/u6gg/ts1201.u6gg/hf_cache
export PYTHONUNBUFFERED=1

cd "$SLURM_SUBMIT_DIR"
export PYTHONPATH="$PWD:${PYTHONPATH:-}"

STEP="${STEP:-500}"
CKPT_DIR="/projects/u6gg/KG_GRPO/checkpoints/kg-align-verl/grpo-cwq-llama-8b-verifiable-20260331"
BASE_MODEL="outputs/verl-sft-llama-8b-merged"
TRAJ_DIR="results/trajectories/llama_e3"

echo "=== Llama E3 Eval: step $STEP (max_turns=3) ==="
echo "Date: $(date)"

# Start KG server
python -m src_verl.kg_server.server --kg freebase --freebase_dir data/freebase/kg --port 18901 --log-level warning &
KG_PID=$!
sleep 30
for i in $(seq 1 12); do
    curl -s -o /dev/null -w "%{http_code}" http://localhost:18901/health 2>/dev/null | grep -q "200" && break
    sleep 10
done

mkdir -p results "$TRAJ_DIR"

python scripts/eval_with_tools.py \
    --checkpoint_dir "$CKPT_DIR" \
    --steps "$STEP" \
    --base_model "$BASE_MODEL" \
    --eval_data data/freebase/verl_cwq/val.parquet \
    --output "results/eval_llama_e3_step${STEP}.json" \
    --kg_server_url http://localhost:18901 \
    --max_samples 500 \
    --max_turns 3 \
    --save_trajectories "$TRAJ_DIR" \
    --max_trajectory_samples 100

kill $KG_PID 2>/dev/null
echo "=== Done: $(date) ==="
