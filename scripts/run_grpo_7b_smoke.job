#!/usr/bin/env bash
#SBATCH --job-name=grpo_7b_smoke
#SBATCH --nodes=1
#SBATCH --gpus=2
#SBATCH --time=02:00:00
#SBATCH --output=logs/%x-%j.log
#SBATCH --error=logs/%x-%j.err
#SBATCH --partition=workq

# 7B GRPO smoke test on 1x GH200 (120GB)
# Purpose: estimate per-step time to check if full training fits in 24h
# Config: 7B SFT-warmed model, 100 samples, ~8 steps, batch_size=16

set -eo pipefail

source "$HOME/miniforge3/bin/activate"
conda activate kg_verl
module load cudatoolkit 2>/dev/null || true
module load gcc-native/14.2 2>/dev/null || true
module load brics/nccl 2>/dev/null || true

export CC=gcc CXX=g++
export LIBRARY_PATH=/opt/nvidia/hpc_sdk/Linux_aarch64/24.11/REDIST/math_libs/12.6/targets/sbsa-linux/lib:${LIBRARY_PATH:-}
export TRITON_CACHE_DIR=/scratch/u6gg/ts1201.u6gg/.triton
export HF_HOME="${SCRATCH:-$SCRATCHDIR}/hf_cache"
export PYTHONUNBUFFERED=1
export VLLM_USE_V1=1
export RAY_DEDUP_LOGS=0
export WANDB_MODE=disabled

cd "$SLURM_SUBMIT_DIR"
export PYTHONPATH="$PWD:${PYTHONPATH:-}"

echo "=== 7B GRPO Smoke Test (1x GH200) ==="
echo "Date: $(date)"
echo "Node: $(hostname)"
echo "GPU: $(nvidia-smi --query-gpu=name,memory.total --format=csv,noheader)"
echo ""

# --- Create 100-sample smoke data ---
python -c "
import pandas as pd
from pathlib import Path
smoke_dir = Path('data/processed/verl_conceptnet_smoke')
smoke_dir.mkdir(parents=True, exist_ok=True)
df = pd.read_parquet('data/processed/verl_conceptnet/train.parquet')
df.head(100).to_parquet(smoke_dir / 'train.parquet')
df.tail(16).to_parquet(smoke_dir / 'val.parquet')
print(f'Smoke data: {len(df.head(100))} train, 16 val')
"

# --- Start KG server ---
echo "Starting KG server..."
python -m src_verl.kg_server.server --port 18901 &
KG_PID=$!
sleep 5
echo "KG server PID: $KG_PID"
echo ""

ray stop 2>/dev/null || true

echo "=== Launching 7B GRPO ==="
echo "Start: $(date)"
START_TIME=$(date +%s)

python -m verl.trainer.main_ppo \
    --config-path="$PWD/configs_verl" \
    --config-name=grpo_conceptnet_7b \
    trainer.experiment_name=smoke-7b-1gpu \
    data.train_files="['data/processed/verl_conceptnet_smoke/train.parquet']" \
    data.val_files="['data/processed/verl_conceptnet_smoke/val.parquet']" \
    data.return_raw_chat=true \
    data.train_batch_size=16 \
    data.shuffle=false \
    algorithm.adv_estimator=grpo \
    actor_rollout_ref.model.path=outputs/verl-sft-7b-merged \
    actor_rollout_ref.actor.ppo_mini_batch_size=16 \
    actor_rollout_ref.actor.ppo_micro_batch_size_per_gpu=1 \
    data.max_response_length=1024 \
    actor_rollout_ref.rollout.n=4 \
    actor_rollout_ref.rollout.gpu_memory_utilization=0.5 \
    actor_rollout_ref.rollout.enforce_eager=true \
    actor_rollout_ref.rollout.tensor_model_parallel_size=1 \
    +actor_rollout_ref.rollout.enable_sleep_mode=true \
    actor_rollout_ref.rollout.checkpoint_engine.update_weights_bucket_megabytes=4096 \
    trainer.n_gpus_per_node=2 \
    trainer.total_epochs=1 \
    trainer.save_freq=9999 \
    trainer.test_freq=9999 \
    "trainer.logger=[]" \
    data.dataloader_num_workers=0 \
    ray_kwargs.ray_init.num_cpus=144
GRPO_EXIT=$?

END_TIME=$(date +%s)
ELAPSED=$((END_TIME - START_TIME))

echo ""
echo "=== Results ==="
echo "Exit code: $GRPO_EXIT"
echo "Total time: ${ELAPSED}s ($((ELAPSED / 60))m)"
echo ""

# --- Estimate full training time ---
# 100 samples, batch_size=16 → ~6 steps per epoch
# Full: 4000 samples, batch_size=64 → 62 steps per epoch × 3 epochs = ~187 steps
# With batch_size=16 on 1 GPU: 250 steps per epoch × 3 = 750 steps
STEPS_RUN=6  # 100 / 16 ≈ 6
if [ $GRPO_EXIT -eq 0 ] && [ $ELAPSED -gt 0 ]; then
    PER_STEP=$((ELAPSED / STEPS_RUN))
    echo "Per-step time: ~${PER_STEP}s"
    echo ""
    echo "=== Time estimates for full training (4000 samples, 3 epochs) ==="
    echo "  batch_size=16, 2 GPU: 750 steps × ${PER_STEP}s = $((750 * PER_STEP / 3600))h"
    echo "  batch_size=32, 2 GPU: 375 steps × ${PER_STEP}s = $((375 * PER_STEP / 3600))h (estimate)"
    echo "  batch_size=64, 2 GPU: 187 steps × ${PER_STEP}s = $((187 * PER_STEP / 3600))h (estimate)"
    echo "  batch_size=64, 4 GPU: 187 steps × ~${PER_STEP}s = $((187 * PER_STEP / 3600))h (same steps, faster per-step)"
    echo "  24h limit threshold: per-step must be < $((24 * 3600 / 187))s for bs=64"
fi

# Cleanup
kill $KG_PID 2>/dev/null
echo ""
echo "=== Done ==="
echo "End: $(date)"
