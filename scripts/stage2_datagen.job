#!/usr/bin/env bash
#SBATCH --job-name=kg_stage2_datagen
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=8
#SBATCH --mem=64G
#SBATCH --time=12:00:00
#SBATCH --account=cs-ontrel-2021
#SBATCH --mail-type=END,FAIL
#SBATCH --mail-user=tianda.sun@york.ac.uk
#SBATCH --output=logs_archive/%x-%j.log
#SBATCH --error=logs_archive/%x-%j.err
#SBATCH --partition=gpuplus
#SBATCH --gpus-per-node=1

# Stage 2: Question Generation + Quality Filtering + Negative Examples
# Expected runtime: ~3-5 hours on H100 with batch_size=16
# Wall time set to 12h for safety margin

set -eo pipefail

# --- Environment Setup ---
module load Miniconda3
module load CUDA/12.1.1
source activate kg_align

export HF_HOME=/mnt/scratch/users/ts1201/hf_cache
export TORCH_HOME=/mnt/scratch/users/ts1201/torch_cache
# HF_TOKEN: load from ~/.huggingface/token or set via `huggingface-cli login`

cd /mnt/scratch/users/ts1201/KG_lora
export PYTHONPATH=$PWD:${PYTHONPATH:-}

echo "=== Stage 2 Starting ==="
echo "Date: $(date)"
echo "Node: $(hostname)"
echo "GPU: $(nvidia-smi --query-gpu=name --format=csv,noheader)"
echo ""

# --- Stage 2a: Question Generation ---
echo "=== Stage 2a: Question Generation ==="
echo "Start: $(date)"

python src/datagen/question_generator.py \
    --paths_file data/processed/conceptnet_paths.jsonl \
    --output_file data/processed/conceptnet_qa_raw.jsonl \
    --model_name Qwen/Qwen2.5-7B-Instruct \
    --batch_size 16 \
    --variants_per_path 2 \
    --max_new_tokens 512 \
    --temperature 0.7 \
    --seed 42 \
    --resume

echo "Stage 2a complete: $(date)"
echo "Raw QA count: $(wc -l < data/processed/conceptnet_qa_raw.jsonl)"
echo ""

# --- Stage 2b: Quality Filtering ---
echo "=== Stage 2b: Quality Filtering ==="
echo "Start: $(date)"

python src/datagen/quality_filter.py \
    --input_file data/processed/conceptnet_qa_raw.jsonl \
    --output_dir data/processed \
    --model_name Qwen/Qwen2.5-7B-Instruct \
    --min_score 4 \
    --batch_size 16 \
    --target_total 5000 \
    --train_count 4000 \
    --val_count 500 \
    --test_count 500 \
    --seed 42

echo "Stage 2b complete: $(date)"
echo "Train count: $(wc -l < data/processed/conceptnet_qa_train.jsonl)"
echo "Val count:   $(wc -l < data/processed/conceptnet_qa_val.jsonl)"
echo "Test count:  $(wc -l < data/processed/conceptnet_qa_test.jsonl)"
echo ""

# --- Stage 2c: Negative Examples (CPU only, fast) ---
echo "=== Stage 2c: Negative Examples ==="
echo "Start: $(date)"

python src/datagen/negative_examples.py \
    --train_file data/processed/conceptnet_qa_train.jsonl \
    --paths_file data/processed/conceptnet_paths.jsonl \
    --output_file data/processed/conceptnet_qa_train_with_neg.jsonl \
    --num_negatives 500 \
    --seed 42

echo "Stage 2c complete: $(date)"
echo "Train+neg count: $(wc -l < data/processed/conceptnet_qa_train_with_neg.jsonl)"
echo ""

# --- Summary ---
echo "=== Stage 2 Complete ==="
echo "End: $(date)"
echo ""
echo "Output files:"
ls -lh data/processed/conceptnet_qa_*.jsonl
