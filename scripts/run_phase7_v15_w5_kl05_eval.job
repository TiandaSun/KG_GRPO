#!/usr/bin/env bash
#SBATCH --job-name=p7_w5_kl05_eval
#SBATCH --nodes=1
#SBATCH --gpus=4
#SBATCH --cpus-per-task=72
#SBATCH --time=12:00:00
#SBATCH --output=logs/%x-%j.log
#SBATCH --error=logs/%x-%j.err
#SBATCH --partition=workq

# v15 Lane 4 — W5 KL ablation eval pack (KL=05).
# Runs full 3531 CWQ test eval at saved steps {100,200,300,400,500}.
# Layout: GPU 0..3 evaluate steps 100/200/300/400 in parallel; step 500 runs on
# GPU 0 once it's free (sequential after the parallel batch).

set -eo pipefail

source "$HOME/miniforge3/bin/activate"
conda activate kg_verl
module load cudatoolkit 2>/dev/null || true
module load gcc-native/14.2 2>/dev/null || true

export CC=gcc CXX=g++
export LIBRARY_PATH=/opt/nvidia/hpc_sdk/Linux_aarch64/24.11/REDIST/math_libs/12.6/targets/sbsa-linux/lib:${LIBRARY_PATH:-}
export HF_HOME=/scratch/u6gg/ts1201.u6gg/hf_cache
export PYTHONUNBUFFERED=1
export TMPDIR="/tmp"
export TRITON_CACHE_DIR=/scratch/u6gg/ts1201.u6gg/.triton

cd "$SLURM_SUBMIT_DIR"
export PYTHONPATH="$PWD:${PYTHONPATH:-}"

KLNORM=05
EXPERIMENT="grpo-cwq-7b-w5-kl${KLNORM}-20260505"
BASE_MODEL="outputs/verl-sft-cwq-7b-G2-from-base-sft-merged"   # tokenizer source
KG_PORT=$((19500 + SLURM_JOB_ID % 100 + 100))   # eval port range different from GRPO

mkdir -p results/phase7 logs

echo "=== W5 KL=${KLNORM} eval pack (4x GH200) ==="
echo "Date: $(date)"
echo "Experiment: $EXPERIMENT"

# --- ONE shared KG server for all evals ---
python -m src_verl.kg_server.server --kg freebase --freebase_dir data/freebase/kg --port $KG_PORT --log-level warning &
KG_PID=$!
trap 'kill $KG_PID 2>/dev/null; wait 2>/dev/null' EXIT
sleep 30
for i in $(seq 1 12); do
    curl -s -o /dev/null -w "%{http_code}" http://localhost:$KG_PORT/health 2>/dev/null | grep -q "200" && break
    sleep 10
done
echo "KG server ready on port $KG_PORT"

run_eval() {
    local idx="$1"     # CUDA device index
    local step="$2"
    local src="/projects/u6gg/KG_GRPO/checkpoints/kg-align-verl/${EXPERIMENT}/global_step_${step}/actor"
    local dst="outputs/verl-sft-cwq-w5-kl${KLNORM}_step${step}-merged"
    local out_json="results/phase7/w5_kl${KLNORM}_step${step}_full_test.json"
    local ps_dir="results/phase7/w5_kl${KLNORM}_step${step}_full_per_sample"
    local logfile="logs/p7_w5_kl${KLNORM}_eval-${SLURM_JOB_ID}-gpu${idx}-step${step}.log"

    mkdir -p "$ps_dir" results/phase7

    echo "[GPU $idx] step=$step  ->  $logfile"

    if [ ! -d "$src" ]; then
        echo "[GPU $idx] ERROR: FSDP ckpt not at $src" | tee -a "$logfile"
        return 1
    fi

    {
        echo "=== GPU $idx step=$step  $(date) ==="
        if [ ! -f "$dst/config.json" ]; then
            echo "Merging FSDP -> HF"
            mkdir -p "$dst"
            CUDA_VISIBLE_DEVICES=$idx python -m verl.model_merger merge --backend fsdp --local_dir "$src" --target_dir "$dst"
            if [ ! -f "$dst/tokenizer.json" ]; then
                cp -n "$BASE_MODEL"/tokenizer* "$dst/" 2>/dev/null || true
                cp -n "$BASE_MODEL"/chat_template.jinja "$dst/" 2>/dev/null || true
            fi
        else
            echo "[skip] merged ckpt already at $dst"
        fi
        CUDA_VISIBLE_DEVICES=$idx python scripts/eval_with_tools.py \
            --checkpoint_dir "$dst" \
            --steps 0 \
            --base_model "$dst" \
            --eval_data data/freebase/verl_cwq/test.parquet \
            --output "$out_json" \
            --kg_server_url http://localhost:$KG_PORT \
            --max_samples 0 \
            --max_turns 5 \
            --max_new_tokens 512 \
            --save_per_sample "$ps_dir"
        echo "=== GPU $idx step=$step done $(date) ==="
    } > "$logfile" 2>&1
}

# --- Phase A: parallel evals on 4 GPUs ---
run_eval 0 100 &
PID0=$!
run_eval 1 200 &
PID1=$!
run_eval 2 300 &
PID2=$!
run_eval 3 400 &
PID3=$!

fail=0
wait $PID0 || { echo "GPU 0 (step 100) failed"; fail=1; }
wait $PID1 || { echo "GPU 1 (step 200) failed"; fail=1; }
wait $PID2 || { echo "GPU 2 (step 300) failed"; fail=1; }
wait $PID3 || { echo "GPU 3 (step 400) failed"; fail=1; }

# --- Phase B: step 500 on GPU 0 (sequential after the batch) ---
run_eval 0 500 || { echo "GPU 0 (step 500) failed"; fail=1; }

kill $KG_PID 2>/dev/null
echo ""
echo "=== All steps done $(date) ==="
echo "Output JSONs:"
for step in 100 200 300 400 500; do
    f="results/phase7/w5_kl${KLNORM}_step${step}_full_test.json"
    if [ -f "$f" ]; then
        echo "  ✓ $f"
        python3 -c "import json; d=json.load(open('$f')); s=d['0']; print(f'    kl=${KLNORM} step=$step EM={s[\"em\"]:.4f} ContEM={s[\"contains_em\"]:.4f} F1={s[\"f1\"]:.4f} Tools={s[\"avg_tool_calls\"]:.2f}')" 2>/dev/null || true
    else
        echo "  ✗ missing: $f"
    fi
done
exit $fail
