#!/usr/bin/env bash
#SBATCH --job-name=grpo_39i_o
#SBATCH --nodes=1
#SBATCH --gpus=4
#SBATCH --time=24:00:00
#SBATCH --output=logs/%x-%j.log
#SBATCH --error=logs/%x-%j.err
#SBATCH --partition=workq

# Task 39 Variant I-Oracle: diagnostic upper bound via oracle-supervised query match.
#
# Init from 39B@400 (the KL-5x survivor, EM=36% @ 200-Q, format stable past step 500).
# Uses tool_type_bonus_oracle_query_match reward with 3 anti-spam defenses:
#   1. Dedup (entity, relation) across turns
#   2. ≥2 distinct gold matches required to unlock reward
#   3. Trajectory-level (matched_unique / distinct_calls)
# Reward weight ramps 0.10 → 0.25 over first 50 steps (ToolRL lesson).
#
# v11 paper framing: NOT claimed as deployable method. This is a DIAGNOSTIC
# UPPER BOUND — "if we could access the gold query structure, how much better
# does the model get?" Paired with I-Self (deployable) for the key comparison.
#
# Training data: train_with_oracle.parquet (18,580 rows with BFS-filtered gold
# triple chains joined from train_oracle_gold_paths.jsonl)

set -eo pipefail

source "$HOME/miniforge3/bin/activate"
conda activate kg_verl
module load cudatoolkit 2>/dev/null || true
module load gcc-native/14.2 2>/dev/null || true
module load brics/nccl 2>/dev/null || true

export CC=gcc CXX=g++
export LIBRARY_PATH=/opt/nvidia/hpc_sdk/Linux_aarch64/24.11/REDIST/math_libs/12.6/targets/sbsa-linux/lib:${LIBRARY_PATH:-}
export TRITON_CACHE_DIR=/scratch/u6gg/ts1201.u6gg/.triton
export HF_HOME=/scratch/u6gg/ts1201.u6gg/hf_cache
export PYTHONUNBUFFERED=1
export VLLM_USE_V1=1
export RAY_DEDUP_LOGS=1
export RAY_TMPDIR="/tmp/ray-${SLURM_JOB_ID}"
mkdir -p "$RAY_TMPDIR"

cd "$SLURM_SUBMIT_DIR"
export PYTHONPATH="$PWD:${PYTHONPATH:-}"

export REWARD_TYPE=tool_type_bonus_oracle_query_match
EXPERIMENT_NAME="grpo-cwq-7b-39i-oracle-20260415"
INIT_BASE="outputs/verl-sft-cwq-39b-step400"
TRAIN_FILE="data/freebase/verl_cwq/train_with_oracle.parquet"

echo "=== Task 39 Variant I-Oracle (4x GH200) ==="
echo "Date: $(date)"
echo "Reward: $REWARD_TYPE (ramp 0.10 → 0.25 over first 50 steps)"
echo "Experiment: $EXPERIMENT_NAME"
echo "Init: $INIT_BASE  (39B @ step 400)"
echo "Train: $TRAIN_FILE"

if [ ! -d "$INIT_BASE" ]; then
    echo "ERROR: init base not found at $INIT_BASE"
    echo "First run: scripts/merge_sft_adapter.py or an FSDP→HF merge on 39B/global_step_400"
    exit 1
fi
if [ ! -f "$TRAIN_FILE" ]; then
    echo "ERROR: $TRAIN_FILE not found — run phase7_prepare_oracle_train_parquet.py"
    exit 1
fi

# KG server
python -m src_verl.kg_server.server --kg freebase --freebase_dir data/freebase/kg --port 18901 --log-level warning &
KG_PID=$!
trap 'kill $KG_PID 2>/dev/null' EXIT
sleep 30
for i in $(seq 1 12); do
    curl -s -o /dev/null -w "%{http_code}" http://localhost:18901/health 2>/dev/null | grep -q "200" && break
    sleep 10
done
echo "KG server ready"

ray stop 2>/dev/null || true

python -m verl.trainer.main_ppo \
    --config-path="$PWD/configs_verl" \
    --config-name=grpo_cwq_7b \
    trainer.experiment_name="$EXPERIMENT_NAME" \
    trainer.total_training_steps=400 \
    actor_rollout_ref.model.path="$INIT_BASE" \
    actor_rollout_ref.actor.use_kl_loss=true \
    actor_rollout_ref.actor.kl_loss_coef=0.05 \
    actor_rollout_ref.actor.kl_loss_type=low_var_kl \
    actor_rollout_ref.actor.optim.lr=3e-7 \
    "data.train_files=[$TRAIN_FILE]" \
    +actor_rollout_ref.rollout.enable_sleep_mode=true \
    actor_rollout_ref.rollout.agent.default_agent_loop=tool_agent \
    data.dataloader_num_workers=0

kill $KG_PID 2>/dev/null
echo "=== Done: $(date) ==="
