#!/usr/bin/env bash
#SBATCH --job-name=verl_sft
#SBATCH --nodes=1
#SBATCH --gpus=1
#SBATCH --time=06:00:00
#SBATCH --output=logs/%x-%j.log
#SBATCH --error=logs/%x-%j.err
#SBATCH --partition=workq

# SFT warmup for multi-turn KG agent (1x GH200, Isambard)
# Each GH200 GPU allocation includes 72 CPU cores + 115GB RAM.
#
# Usage: sbatch scripts/train_verl_sft_isambard.job

set -eo pipefail

# --- Environment Setup (Isambard ARM GH200) ---
source "$HOME/miniforge3/bin/activate"
conda activate kg_verl
module load cudatoolkit 2>/dev/null || true

cd "$SLURM_SUBMIT_DIR"
export PYTHONPATH="$PWD:${PYTHONPATH:-}"
export HF_HOME="${SCRATCH:-$SCRATCHDIR}/hf_cache"
export TORCH_HOME="${SCRATCH:-$SCRATCHDIR}/torch_cache"
export WANDB_PROJECT=kg-align-verl

mkdir -p logs outputs/verl-sft

echo "=== SFT Warmup (multi-turn, Isambard GH200) ==="
echo "Date: $(date)"
echo "Node: $(hostname)"
echo "GPU: $(nvidia-smi --query-gpu=name --format=csv,noheader)"
echo "Model: Qwen/Qwen2.5-1.5B-Instruct"
echo ""

python src_verl/training/sft_multiturn.py \
    --config configs_verl/sft_multiturn.yaml

echo ""
echo "=== SFT Training Complete ==="
echo ""

# --- Merge LoRA adapter into base model ---
echo "=== Merging SFT adapter into base model ==="
python scripts/merge_sft_adapter.py \
    --base_model Qwen/Qwen2.5-1.5B-Instruct \
    --adapter_path outputs/verl-sft \
    --output_path outputs/verl-sft-merged

echo ""
echo "=== SFT + Merge Complete ==="
echo "End: $(date)"
ls -lh outputs/verl-sft-merged/
