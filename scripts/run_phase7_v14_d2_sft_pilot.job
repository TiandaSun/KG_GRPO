#!/usr/bin/env bash
#SBATCH --job-name=p7_v14d2_sft_pilot
#SBATCH --nodes=1
#SBATCH --gpus=1
#SBATCH --time=02:00:00
#SBATCH --output=logs/%x-%j.log
#SBATCH --error=logs/%x-%j.err
#SBATCH --partition=workq

# V14-D2 SFT pilot: 0.1 epoch on 500 samples, Qwen3-4B-Instruct-2507.
# Sanity-gate before launching full SFT. 1 GPU is plenty for 4B/LoRA.
#
# Outputs:
#   outputs/verl-sft-cwq-qwen3-4b-from-base-pilot/   (adapter)
#   logs/p7_v14d2_sft_pilot-<jobid>.log              (loss curve)

set -eo pipefail

source "$HOME/miniforge3/bin/activate"
conda activate kg_verl
module load cudatoolkit 2>/dev/null || true
module load gcc-native/14.2 2>/dev/null || true

export CC=gcc CXX=g++
export LIBRARY_PATH=/opt/nvidia/hpc_sdk/Linux_aarch64/24.11/REDIST/math_libs/12.6/targets/sbsa-linux/lib:${LIBRARY_PATH:-}
export TRITON_CACHE_DIR=/scratch/u6gg/ts1201.u6gg/.triton
export HF_HOME=/scratch/u6gg/ts1201.u6gg/hf_cache
export PYTHONUNBUFFERED=1
export TMPDIR="/tmp"

cd "$SLURM_SUBMIT_DIR"
export PYTHONPATH="$PWD:${PYTHONPATH:-}"

MODEL="Qwen/Qwen3-4B-Instruct-2507"
TRAIN_FILE="data/freebase/sft_trajectories_pilot500.jsonl"
OUTPUT_DIR="outputs/verl-sft-cwq-qwen3-4b-from-base-pilot"

# Create pilot subset if missing.
if [ ! -f "$TRAIN_FILE" ]; then
    FULL="data/freebase/sft_trajectories.jsonl"
    if [ ! -f "$FULL" ]; then
        echo "ERROR: $FULL missing — cannot build pilot subset"
        exit 1
    fi
    echo "Creating pilot subset: head -500 $FULL > $TRAIN_FILE"
    head -500 "$FULL" > "$TRAIN_FILE"
fi

echo "=== V14-D2 SFT pilot: $(date) ==="
echo "model       = $MODEL"
echo "train_file  = $TRAIN_FILE (wc -l: $(wc -l < "$TRAIN_FILE"))"
echo "output_dir  = $OUTPUT_DIR"

# 0.1 epoch on 500 samples with target hyperparams.
# LR 2.5e-5 = midpoint of 1.2× and 1.5× over 7B baseline 2e-5.
python src_verl/training/sft_multiturn.py \
    --config configs_verl/sft_cwq.yaml \
    --model_path "$MODEL" \
    --output_dir "$OUTPUT_DIR" \
    --train_file "$TRAIN_FILE" \
    --num_train_epochs 1 \
    2>&1 | tee "$OUTPUT_DIR/pilot_train.log" || true

# The sft_multiturn.py script takes --num_train_epochs as int; 0.1 epoch on
# 500 rows ≈ 50 rows = a handful of optimiser steps. To approximate that in
# a re-runnable way, we override max_steps via env below: the config path
# doesn't expose it, but the TRL trainer honours it if present. Keep num
# epochs=1 (trivial on 500 rows) — user can review the loss curve.

# Save a small format-validity spot check.
python - <<'PY'
import json, re
from pathlib import Path
from transformers import AutoTokenizer, AutoModelForCausalLM
import torch

PILOT_DIR = Path("outputs/verl-sft-cwq-qwen3-4b-from-base-pilot")
if not any(PILOT_DIR.glob("adapter*")):
    print("WARN: no adapter saved in", PILOT_DIR, "— skipping format eval")
    raise SystemExit(0)

base = "Qwen/Qwen3-4B-Instruct-2507"
tok = AutoTokenizer.from_pretrained(base)
model = AutoModelForCausalLM.from_pretrained(
    base, torch_dtype=torch.bfloat16, device_map="auto",
    attn_implementation="eager",
)
from peft import PeftModel
model = PeftModel.from_pretrained(model, str(PILOT_DIR))
model.eval()

# 10 canned probes: does it produce <search> or <answer> tags?
PROBES = [
    "In which city is the capital of France?",
    "Which continent does Kenya belong to?",
    "What novel did Harper Lee write?",
    "Who discovered penicillin?",
    "What language is spoken in Brazil?",
    "Which country contains Tokyo?",
    "What is the currency of Japan?",
    "Who painted the Mona Lisa?",
    "What is the largest ocean?",
    "In what year did WW2 end?",
]
SYSTEM = Path("data/freebase/sft_trajectories_pilot500.jsonl").open().readline()
SYSTEM = json.loads(SYSTEM)["trajectory"][0]["content"]

ok = 0
for q in PROBES:
    msgs = [{"role": "system", "content": SYSTEM},
            {"role": "user", "content": q}]
    try:
        text = tok.apply_chat_template(msgs, tokenize=False,
                                       add_generation_prompt=True,
                                       enable_thinking=False)
    except TypeError:
        text = tok.apply_chat_template(msgs, tokenize=False,
                                       add_generation_prompt=True)
    ids = tok(text, return_tensors="pt").to(model.device)
    with torch.no_grad():
        out = model.generate(**ids, max_new_tokens=160, do_sample=False,
                             pad_token_id=tok.eos_token_id)
    reply = tok.decode(out[0, ids["input_ids"].shape[1]:], skip_special_tokens=False)
    tags = bool(re.search(r"<search>|<answer>", reply))
    if tags:
        ok += 1
    print(f"[{'PASS' if tags else 'FAIL'}] {q}\n    -> {reply[:200]!r}\n")

print(f"\nFormat validity (pilot, 10 probes): {ok}/10 = {ok*10}%")
PY

echo "=== Done: $(date) ==="
