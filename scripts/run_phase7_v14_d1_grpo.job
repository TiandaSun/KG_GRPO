#!/usr/bin/env bash
#SBATCH --job-name=p7_v14d1_grpo
#SBATCH --nodes=1
#SBATCH --gpus=4
#SBATCH --time=24:00:00
#SBATCH --output=logs/%x-%j.log
#SBATCH --error=logs/%x-%j.err
#SBATCH --partition=workq

# V14-D1 Qwen2.5-14B E5b-stabilized — GRPO training.
#
# Recipe (mirrors 7B E5b winner + 39G-arm KL 5x):
#   - Reward: tool_type_bonus (E5b)
#   - use_kl_loss=true, kl_loss_coef=0.05, kl_loss_type=low_var_kl
#   - trainer.total_training_steps=500 (target). Hard eval points: 200 / 400.
#     If 24h walltime can't fit 500 steps, verl's save_freq=50 guarantees a
#     useful checkpoint is available; re-launch with
#     `trainer.total_training_steps=300` if needed.
#   - 4 GPUs. Use vLLM tensor_model_parallel_size=2 for 14B (rollout needs
#     ~28GB/GPU at TP=2; 7B's TP=1 doesn't fit at 14B).
#   - actor micro batch = 1 (14B requires half the 7B microbatch).
#
# Reuses configs_verl/grpo_cwq_7b.yaml unchanged — all 14B-specific knobs are
# command-line overrides here, so the 7B config is never mutated.

set -eo pipefail

source "$HOME/miniforge3/bin/activate"
conda activate kg_verl
module load cudatoolkit 2>/dev/null || true
module load gcc-native/14.2 2>/dev/null || true
module load brics/nccl 2>/dev/null || true

export CC=gcc CXX=g++
export LIBRARY_PATH=/opt/nvidia/hpc_sdk/Linux_aarch64/24.11/REDIST/math_libs/12.6/targets/sbsa-linux/lib:${LIBRARY_PATH:-}
export TRITON_CACHE_DIR=/scratch/u6gg/ts1201.u6gg/.triton
export HF_HOME=/scratch/u6gg/ts1201.u6gg/hf_cache
export PYTHONUNBUFFERED=1
export VLLM_USE_V1=1
export RAY_DEDUP_LOGS=1
export RAY_TMPDIR="/tmp/ray-${SLURM_JOB_ID}"
export TMPDIR="/tmp"
mkdir -p "$RAY_TMPDIR"

cd "$SLURM_SUBMIT_DIR"
export PYTHONPATH="$PWD:${PYTHONPATH:-}"

export REWARD_TYPE=tool_type_bonus

INIT_BASE="outputs/verl-sft-cwq-14b-from-base-merged"
EXPERIMENT_NAME="grpo-cwq-14b-e5b-20260420"

echo "=== V14-D1 Qwen2.5-14B GRPO (E5b-stabilized) ==="
echo "Date: $(date)"
echo "Init: $INIT_BASE"
echo "Experiment: $EXPERIMENT_NAME"
echo "REWARD_TYPE=$REWARD_TYPE"

if [ ! -d "$INIT_BASE" ]; then
    echo "ERROR: merged SFT checkpoint not found at $INIT_BASE"
    echo "Run scripts/run_phase7_v14_d1_sft_full.job first."
    exit 1
fi

# --- KG server (in-job, not login) ---
KG_PORT=$((18000 + SLURM_JOB_ID % 1000))
python -m src_verl.kg_server.server --kg freebase --freebase_dir data/freebase/kg --port $KG_PORT --log-level warning &
KG_PID=$!
trap 'kill $KG_PID 2>/dev/null' EXIT
sleep 30
for i in $(seq 1 12); do
    curl -s -o /dev/null -w "%{http_code}" http://localhost:$KG_PORT/health 2>/dev/null | grep -q "200" && break
    sleep 10
done
echo "KG server ready on port $KG_PORT"

# Point the tool config at this port.  verl reads configs_verl/kg_tool_config_freebase.yaml;
# if it hardcodes a port, we override via env var consumed by the KG tool wrapper.
# (Mirrors pattern used by 39G grpo job — default port 18901 is what the tool yaml expects.)
# If your tool config uses port 18901, we re-expose via SSH-like socat is not needed;
# the 39G job uses 18901 directly. Align with that convention:
if [ "$KG_PORT" != "18901" ]; then
    # Re-start server on the canonical 18901 port if available, else export KG_SERVER_URL.
    export KG_SERVER_URL="http://localhost:$KG_PORT"
    echo "Non-canonical port: exporting KG_SERVER_URL=$KG_SERVER_URL"
fi

ray stop 2>/dev/null || true

python -m verl.trainer.main_ppo \
    --config-path="$PWD/configs_verl" \
    --config-name=grpo_cwq_7b \
    trainer.experiment_name="$EXPERIMENT_NAME" \
    trainer.total_training_steps=500 \
    actor_rollout_ref.model.path="$INIT_BASE" \
    actor_rollout_ref.actor.use_kl_loss=true \
    actor_rollout_ref.actor.kl_loss_coef=0.05 \
    actor_rollout_ref.actor.kl_loss_type=low_var_kl \
    actor_rollout_ref.actor.ppo_micro_batch_size_per_gpu=1 \
    actor_rollout_ref.ref.log_prob_micro_batch_size_per_gpu=1 \
    actor_rollout_ref.rollout.tensor_model_parallel_size=4 \
    actor_rollout_ref.rollout.log_prob_micro_batch_size_per_gpu=1 \
    actor_rollout_ref.rollout.gpu_memory_utilization=0.45 \
    actor_rollout_ref.rollout.max_num_seqs=64 \
    actor_rollout_ref.rollout.max_num_batched_tokens=4096 \
    +actor_rollout_ref.rollout.enable_sleep_mode=true \
    actor_rollout_ref.rollout.agent.default_agent_loop=tool_agent \
    data.dataloader_num_workers=0

kill $KG_PID 2>/dev/null
echo "=== Done: $(date) ==="
