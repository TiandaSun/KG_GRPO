#!/usr/bin/env bash
#SBATCH --job-name=p7_s01_pack4
#SBATCH --nodes=1
#SBATCH --gpus=4
#SBATCH --cpus-per-task=72
#SBATCH --time=12:00:00
#SBATCH --output=logs/%x-%j.log
#SBATCH --error=logs/%x-%j.err
#SBATCH --partition=workq

# S0.1 packed eval: 4 (seed, step) evals share one 4-GPU node allocation.
# This counts as ONE job against the per-user cap (currently QOSMaxJobsPerUser=1)
# but produces 4 eval results, cutting wall-clock by 4x at low cap.
#
# Usage:
#   sbatch --export=ALL,P0=1:50,P1=1:100,P2=1:150,P3=1:200 scripts/run_phase7_s01_eval_pack4.job
#
# P0..P3 are SEED:STEP tuples. Use "skip" for any slot that's not needed.
# Example: P0=2:50 P1=2:100 P2=skip P3=skip uses only 2 of 4 GPUs.

set -eo pipefail

source "$HOME/miniforge3/bin/activate"
conda activate kg_verl
module load cudatoolkit 2>/dev/null || true
module load gcc-native/14.2 2>/dev/null || true

export CC=gcc CXX=g++
export LIBRARY_PATH=/opt/nvidia/hpc_sdk/Linux_aarch64/24.11/REDIST/math_libs/12.6/targets/sbsa-linux/lib:${LIBRARY_PATH:-}
export HF_HOME=/scratch/u6gg/ts1201.u6gg/hf_cache
export PYTHONUNBUFFERED=1
export TMPDIR="/tmp"
export TRITON_CACHE_DIR=/scratch/u6gg/ts1201.u6gg/.triton

cd "$SLURM_SUBMIT_DIR"
export PYTHONPATH="$PWD:${PYTHONPATH:-}"

P0="${P0:-skip}"
P1="${P1:-skip}"
P2="${P2:-skip}"
P3="${P3:-skip}"

BASE_MODEL="outputs/verl-sft-cwq-39b-step400"
KG_PORT=$((19000 + SLURM_JOB_ID % 100))

echo "=== S0.1 packed-4 eval ==="
echo "Date: $(date)"
echo "Slots: P0=$P0 P1=$P1 P2=$P2 P3=$P3"

# --- ONE shared KG server for all 4 evals ---
python -m src_verl.kg_server.server --kg freebase --freebase_dir data/freebase/kg --port $KG_PORT --log-level warning &
KG_PID=$!
trap 'kill $KG_PID 2>/dev/null; wait 2>/dev/null' EXIT
sleep 30
for i in $(seq 1 12); do
    curl -s -o /dev/null -w "%{http_code}" http://localhost:$KG_PORT/health 2>/dev/null | grep -q "200" && break
    sleep 10
done
echo "KG server ready on port $KG_PORT"

# --- Run 1 eval pinned to one GPU ---
run_eval() {
    local idx="$1"     # CUDA device index (0..3)
    local tuple="$2"   # SEED:STEP
    if [ "$tuple" = "skip" ]; then
        echo "[GPU $idx] skipped"
        return
    fi
    local seed="${tuple%%:*}"
    local step="${tuple##*:}"
    local experiment="grpo-cwq-7b-39i-self-seed${seed}-20260427"
    local src="/projects/u6gg/KG_GRPO/checkpoints/kg-align-verl/${experiment}/global_step_${step}/actor"
    local dst="outputs/verl-sft-cwq-39i_self_seed${seed}_step${step}-merged"
    local out_json="results/phase7/39i_self_seed${seed}_step${step}_full_test.json"
    local ps_dir="results/phase7/39i_self_seed${seed}_step${step}_full_per_sample"
    local logfile="logs/p7_s01_pack4-${SLURM_JOB_ID}-gpu${idx}-seed${seed}-step${step}.log"

    mkdir -p "$ps_dir" results/phase7

    echo "[GPU $idx] seed=$seed step=$step  ->  $logfile"

    if [ ! -d "$src" ]; then
        echo "[GPU $idx] ERROR: FSDP ckpt not at $src" | tee -a "$logfile"
        return 1
    fi

    {
        echo "=== GPU $idx seed=$seed step=$step  $(date) ==="
        # --- merge if needed ---
        if [ ! -f "$dst/config.json" ]; then
            echo "Merging FSDP -> HF"
            mkdir -p "$dst"
            CUDA_VISIBLE_DEVICES=$idx python -m verl.model_merger merge --backend fsdp --local_dir "$src" --target_dir "$dst"
            if [ ! -f "$dst/tokenizer.json" ]; then
                cp -n "$BASE_MODEL"/tokenizer* "$dst/" 2>/dev/null || true
                cp -n "$BASE_MODEL"/chat_template.jinja "$dst/" 2>/dev/null || true
            fi
        else
            echo "[skip] merged ckpt already at $dst"
        fi
        # --- eval ---
        CUDA_VISIBLE_DEVICES=$idx python scripts/eval_with_tools.py \
            --checkpoint_dir "$dst" \
            --steps 0 \
            --base_model "$dst" \
            --eval_data data/freebase/verl_cwq/test.parquet \
            --output "$out_json" \
            --kg_server_url http://localhost:$KG_PORT \
            --max_samples 0 \
            --max_turns 5 \
            --max_new_tokens 512 \
            --save_per_sample "$ps_dir"
        echo "=== GPU $idx done $(date) ==="
    } > "$logfile" 2>&1
}

# --- Launch 4 in parallel ---
run_eval 0 "$P0" &
PID0=$!
run_eval 1 "$P1" &
PID1=$!
run_eval 2 "$P2" &
PID2=$!
run_eval 3 "$P3" &
PID3=$!

# --- Wait for all ---
fail=0
wait $PID0 || { echo "GPU 0 failed"; fail=1; }
wait $PID1 || { echo "GPU 1 failed"; fail=1; }
wait $PID2 || { echo "GPU 2 failed"; fail=1; }
wait $PID3 || { echo "GPU 3 failed"; fail=1; }

kill $KG_PID 2>/dev/null
echo ""
echo "=== All slots done $(date) ==="
echo "Output JSONs:"
for tuple in "$P0" "$P1" "$P2" "$P3"; do
    [ "$tuple" = "skip" ] && continue
    seed="${tuple%%:*}"
    step="${tuple##*:}"
    f="results/phase7/39i_self_seed${seed}_step${step}_full_test.json"
    if [ -f "$f" ]; then
        echo "  ✓ $f"
        python3 -c "import json; d=json.load(open('$f')); s=d['0']; print(f'    seed=$seed step=$step EM={s[\"em\"]:.4f} ContEM={s[\"contains_em\"]:.4f} F1={s[\"f1\"]:.4f} Tools={s[\"avg_tool_calls\"]:.2f}')" 2>/dev/null || true
    else
        echo "  ✗ missing: $f"
    fi
done
exit $fail
