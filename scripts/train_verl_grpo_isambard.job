#!/usr/bin/env bash
#SBATCH --job-name=verl_grpo
#SBATCH --nodes=1
#SBATCH --gpus=4
#SBATCH --time=24:00:00
#SBATCH --output=logs/%x-%j.log
#SBATCH --error=logs/%x-%j.err
#SBATCH --partition=workq

# GRPO training with verl on Isambard (4x GH200 for 7B)
# Each GH200: 120GB HBM3, 72 CPU cores, 115GB Grace RAM.
# 4 GPUs = DDP with TP=1 (each GPU runs its own vLLM engine).
#
# Starts KG server as background process on the same node, then trains.
#
# Set REWARD_TYPE, MODEL_SIZE, CONFIG_NAME before submitting:
#   MODEL_SIZE=1.5b sbatch scripts/train_verl_grpo_isambard.job          # 1.5B on 1 GPU
#   MODEL_SIZE=7b   sbatch scripts/train_verl_grpo_isambard.job          # 7B on 4 GPUs
#
# Prerequisites:
#   - SFT warmup complete (outputs/verl-sft-merged/)
#   - Data prepared (data/processed/verl_conceptnet/train.parquet)

set -eo pipefail

# --- Environment Setup (Isambard ARM GH200) ---
source "$HOME/miniforge3/bin/activate"
conda activate kg_verl
module load cudatoolkit 2>/dev/null || true
module load brics/nccl 2>/dev/null || true  # Required for multi-GPU NCCL

cd "$SLURM_SUBMIT_DIR"
export PYTHONPATH="$PWD:${PYTHONPATH:-}"
export HF_HOME="${SCRATCH:-$SCRATCHDIR}/hf_cache"
export TORCH_HOME="${SCRATCH:-$SCRATCHDIR}/torch_cache"
export VLLM_USE_V1=1
export WANDB_PROJECT=kg-align-verl

# NCCL settings for GH200 Slingshot 11 interconnect
export NCCL_SOCKET_IFNAME="hsn"
export NCCL_NET_GDR_LEVEL="PHB"
export NCCL_CROSS_NIC="1"

MODEL_SIZE=${MODEL_SIZE:-7b}
REWARD_TYPE=${REWARD_TYPE:-verifiable}
EXPERIMENT_NAME=${EXPERIMENT_NAME:-isambard}
KG_PORT=8001

# Select config based on model size
if [[ "$MODEL_SIZE" == "1.5b" ]]; then
    CONFIG_NAME="grpo_conceptnet_1.5b"
    MODEL_PATH="outputs/verl-sft-merged"
    N_GPUS=1
else
    CONFIG_NAME="grpo_conceptnet_7b"
    MODEL_PATH="Qwen/Qwen2.5-7B-Instruct"
    N_GPUS=4
fi

mkdir -p logs

echo "=== verl GRPO Training (${MODEL_SIZE}, Isambard GH200) ==="
echo "Date: $(date)"
echo "Node: $(hostname)"
echo "GPUs: $(nvidia-smi --query-gpu=name --format=csv,noheader | wc -l)x $(nvidia-smi --query-gpu=name --format=csv,noheader | head -1)"
echo "Model: $MODEL_PATH ($MODEL_SIZE)"
echo "Config: $CONFIG_NAME"
echo "Reward: $REWARD_TYPE | Experiment: $EXPERIMENT_NAME"
echo ""

# --- Start KG server as background process ---
echo "Starting KG server on localhost:$KG_PORT ..."
python src_verl/kg_server/server.py \
    --kg conceptnet \
    --assertions_path data/raw/conceptnet-assertions-5.7.0.csv.gz \
    --port "$KG_PORT" \
    --host 0.0.0.0 &
KG_SERVER_PID=$!

echo "Waiting for KG server (PID $KG_SERVER_PID) to start..."
for i in $(seq 1 150); do
    if curl -s "http://localhost:$KG_PORT/health" > /dev/null 2>&1; then
        echo "KG server ready after $((i * 2))s"
        break
    fi
    if ! kill -0 $KG_SERVER_PID 2>/dev/null; then
        echo "ERROR: KG server process died"
        exit 1
    fi
    sleep 2
done

if ! curl -s "http://localhost:$KG_PORT/health" > /dev/null 2>&1; then
    echo "ERROR: KG server did not start within 300s"
    kill $KG_SERVER_PID 2>/dev/null
    exit 1
fi

curl -s "http://localhost:$KG_PORT/health" | python -m json.tool
echo ""

# --- Run GRPO training ---
echo "Starting GRPO training..."
python3 -m verl.trainer.main_ppo \
    --config-path="$PWD/configs_verl" \
    --config-name="$CONFIG_NAME" \
    trainer.experiment_name="grpo-conceptnet-${MODEL_SIZE}-${EXPERIMENT_NAME}-${REWARD_TYPE}" \
    data.train_files="['data/processed/verl_conceptnet/train.parquet']" \
    data.return_raw_chat=true \
    actor_rollout_ref.model.path="$MODEL_PATH" \
    actor_rollout_ref.rollout.multi_turn.tool_config_path="configs_verl/kg_tool_config.yaml" \
    trainer.n_gpus_per_node="$N_GPUS" \
    data.dataloader_num_workers=0
TRAIN_EXIT=$?

# --- Cleanup ---
echo "Stopping KG server (PID $KG_SERVER_PID)..."
kill $KG_SERVER_PID 2>/dev/null
wait $KG_SERVER_PID 2>/dev/null || true

echo ""
echo "=== GRPO Training Complete (exit code: $TRAIN_EXIT) ==="
echo "End: $(date)"
exit $TRAIN_EXIT
