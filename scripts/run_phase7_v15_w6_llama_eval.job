#!/usr/bin/env bash
#SBATCH --job-name=p7_v15_w6_llama_eval
#SBATCH --nodes=1
#SBATCH --gpus=1
#SBATCH --cpus-per-task=72
#SBATCH --time=12:00:00
#SBATCH --output=logs/%x-%j.log
#SBATCH --error=logs/%x-%j.err
#SBATCH --partition=workq

# v15 Lane 5 (W6) Step 3: full 3531 CWQ test eval at one step.
# Merges FSDP -> HF, then runs eval_with_tools on full test set with
# per-sample save. At the final step (highest requested), also dumps full
# trajectories for the 7-cat classification.
#
# Usage:
#   sbatch --export=ALL,STEP=200 scripts/run_phase7_v15_w6_llama_eval.job
#   sbatch --export=ALL,STEP=400 scripts/run_phase7_v15_w6_llama_eval.job
#   sbatch --export=ALL,STEP=600 scripts/run_phase7_v15_w6_llama_eval.job  # auto-falls-back to highest if 600 not saved
#
# Output:
#   results/phase7/v15_w6_llama_step{STEP}_full_test.json
#   results/phase7/v15_w6_llama_step{STEP}_full_per_sample/...
#   results/phase7/v15_w6_llama_step{STEP}_trajectories/...  (final step only)

set -eo pipefail

source "$HOME/miniforge3/bin/activate"
conda activate kg_verl
module load cudatoolkit 2>/dev/null || true
module load gcc-native/14.2 2>/dev/null || true

export CC=gcc CXX=g++
export LIBRARY_PATH=/opt/nvidia/hpc_sdk/Linux_aarch64/24.11/REDIST/math_libs/12.6/targets/sbsa-linux/lib:${LIBRARY_PATH:-}
export HF_HOME=/scratch/u6gg/ts1201.u6gg/hf_cache
export HF_TOKEN=$(cat "$HOME/.cache/huggingface/token" 2>/dev/null)
export PYTHONUNBUFFERED=1
export TMPDIR="/tmp"
export TRITON_CACHE_DIR=/scratch/u6gg/ts1201.u6gg/.triton

cd "$SLURM_SUBMIT_DIR"
export PYTHONPATH="$PWD:${PYTHONPATH:-}"

: "${STEP:?STEP env var required (e.g. 200, 400, 600)}"
FINAL_STEP="${FINAL_STEP:-600}"

EXPERIMENT="grpo-cwq-llama8b-w6-20260505"
BASE_MODEL="outputs/verl-sft-cwq-llama8b-w6-merged"  # tokenizer / chat_template source
CKPT_ROOT="/projects/u6gg/KG_GRPO/checkpoints/kg-align-verl/${EXPERIMENT}"

# --- Resolve actual step (graceful fallback if requested step not saved) ---
REQ_STEP="$STEP"
SRC="${CKPT_ROOT}/global_step_${REQ_STEP}/actor"
if [ ! -d "$SRC" ]; then
    HIGHEST=$(ls "$CKPT_ROOT" 2>/dev/null | grep '^global_step_' | sed 's/global_step_//' | sort -n | tail -1)
    if [ -z "$HIGHEST" ]; then
        echo "ERROR: no checkpoints found in $CKPT_ROOT"
        exit 1
    fi
    echo "[fallback] requested step=$REQ_STEP not found; using highest available step=$HIGHEST"
    STEP="$HIGHEST"
    SRC="${CKPT_ROOT}/global_step_${STEP}/actor"
fi

DST="outputs/verl-sft-cwq-llama8b-w6-step${STEP}-merged"
OUT_JSON="results/phase7/v15_w6_llama_step${STEP}_full_test.json"
PS_DIR="results/phase7/v15_w6_llama_step${STEP}_full_per_sample"
TRAJ_DIR="results/phase7/v15_w6_llama_step${STEP}_trajectories"
KG_PORT=$((19800 + SLURM_JOB_ID % 100))

mkdir -p results/phase7 "$PS_DIR" logs

echo "=== v15 W6 Llama eval requested_step=${REQ_STEP} resolved_step=${STEP} ==="
echo "Date: $(date)"
echo "Src: $SRC"
echo "Dst: $DST"
echo "KG port: $KG_PORT"

[ -d "$SRC" ] || { echo "ERROR: FSDP ckpt not found at $SRC"; exit 1; }
[ -d "$BASE_MODEL" ] || { echo "ERROR: base model dir (tokenizer source) not found at $BASE_MODEL"; exit 1; }

# --- (1) Merge FSDP -> HF ---
if [ ! -f "$DST/config.json" ]; then
    echo "=== Merging FSDP -> HF (Llama 8B) ==="
    mkdir -p "$DST"
    python -m verl.model_merger merge --backend fsdp --local_dir "$SRC" --target_dir "$DST"
    if [ ! -f "$DST/tokenizer.json" ]; then
        cp -n "$BASE_MODEL"/tokenizer* "$DST/" 2>/dev/null || true
        cp -n "$BASE_MODEL"/chat_template.jinja "$DST/" 2>/dev/null || true
    fi
    echo "Merge complete."
else
    echo "[skip] merged ckpt already exists at $DST"
fi

# --- (2) KG server ---
python -m src_verl.kg_server.server --kg freebase --freebase_dir data/freebase/kg --port $KG_PORT --log-level warning &
KG_PID=$!
trap 'kill $KG_PID 2>/dev/null' EXIT
sleep 30
for i in $(seq 1 12); do
    curl -s -o /dev/null -w "%{http_code}" http://localhost:$KG_PORT/health 2>/dev/null | grep -q "200" && break
    sleep 10
done
echo "KG server ready on port $KG_PORT"

# --- (3) Full 3531 eval. Trajectory dump only at the final requested step. ---
EXTRA_ARGS=()
if [ "$REQ_STEP" = "$FINAL_STEP" ]; then
    EXTRA_ARGS+=(--save_trajectories "$TRAJ_DIR" --max_trajectory_samples 3531)
    mkdir -p "$TRAJ_DIR"
    echo "[traj-dump] enabled for final step (req=${REQ_STEP}, resolved=${STEP})"
fi

python scripts/eval_with_tools.py \
    --checkpoint_dir "$DST" \
    --steps 0 \
    --base_model "$DST" \
    --eval_data data/freebase/verl_cwq/test.parquet \
    --output "$OUT_JSON" \
    --kg_server_url http://localhost:$KG_PORT \
    --max_samples 0 \
    --max_turns 5 \
    --max_new_tokens 512 \
    --save_per_sample "$PS_DIR" \
    "${EXTRA_ARGS[@]}"

kill $KG_PID 2>/dev/null
echo "=== Done: $(date) ==="
