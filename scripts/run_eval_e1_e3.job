#!/usr/bin/env bash
#SBATCH --job-name=eval_e1_e3
#SBATCH --nodes=1
#SBATCH --gpus=1
#SBATCH --time=06:00:00
#SBATCH --output=logs/%x-%j.log
#SBATCH --error=logs/%x-%j.err
#SBATCH --partition=workq

# Offline eval of E1 (outcome) and E3 (verifiable) checkpoints
# Evaluates steps {50, 250, 500, 750, 1000, 1250} on CWQ val (500 samples)
# Sequential on 1 GPU — each checkpoint: load model, run 500 inferences, ~15min

set -eo pipefail

source "$HOME/miniforge3/bin/activate"
conda activate kg_verl
module load cudatoolkit 2>/dev/null || true
module load gcc-native/14.2 2>/dev/null || true

export CC=gcc CXX=g++
export HF_HOME=/scratch/u6gg/ts1201.u6gg/hf_cache
export PYTHONUNBUFFERED=1

cd "$SLURM_SUBMIT_DIR"
export PYTHONPATH="$PWD:${PYTHONPATH:-}"

echo "=== Offline Eval: E1 + E3 Checkpoints ==="
echo "Date: $(date)"
echo "Node: $(hostname)"
echo ""

mkdir -p results

# Eval E1 (outcome)
echo "=== Evaluating E1 (R_outcome) ==="
python scripts/eval_checkpoints.py \
    --checkpoint_dir checkpoints/kg-align-verl/grpo-cwq-7b-outcome-20260321 \
    --steps 50 250 500 750 1000 1250 \
    --eval_data data/freebase/verl_cwq/val.parquet \
    --base_model outputs/verl-sft-cwq-7b-merged \
    --output results/eval_e1_outcome.json \
    --max_samples 500
echo ""

# Eval E3 (verifiable)
echo "=== Evaluating E3 (R_verifiable) ==="
python scripts/eval_checkpoints.py \
    --checkpoint_dir checkpoints/kg-align-verl/grpo-cwq-7b-verifiable-20260321 \
    --steps 50 250 500 750 1000 1250 \
    --eval_data data/freebase/verl_cwq/val.parquet \
    --base_model outputs/verl-sft-cwq-7b-merged \
    --output results/eval_e3_verifiable.json \
    --max_samples 500
echo ""

echo "=== Done ==="
echo "End: $(date)"
